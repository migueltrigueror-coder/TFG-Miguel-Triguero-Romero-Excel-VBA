Sub GenerarTablaFlotanteResumen()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim col As Long, i As Long
    Dim leftPos As Double, topPos As Double
    Dim shp As Shape
    Dim ultimaColExamen As Long
    Dim nombresColeccion As New Collection
    
    On Error Resume Next
    ws.Shapes("TablaResumenFlotante").Delete
    On Error GoTo 0
    
    For col = 42 To 38 Step -1
        If InStr(1, ws.Cells(2, col).Value, "Examen", vbTextCompare) > 0 Then
            ultimaColExamen = col
            Exit For
        End If
    Next col

    leftPos = ws.Range("D11").Left
    topPos = ws.Range("D11").Top
    Dim wCol As Double: wCol = 75
    Dim hFil As Double: hFil = 22
    
    CrearCeldaFlotante ws, leftPos, topPos, wCol, 40, "ESTADÍSTICAS", RGB(180, 180, 180), vbWhite, nombresColeccion
    CrearCeldaFlotante ws, leftPos, topPos + 40, wCol, hFil, "Nota Media", RGB(220, 220, 220), vbBlack, nombresColeccion
    CrearCeldaFlotante ws, leftPos, topPos + 40 + hFil, wCol, hFil, "Desv. Típica", RGB(220, 220, 220), vbBlack, nombresColeccion
    CrearCeldaFlotante ws, leftPos, topPos + 40 + (hFil * 2), wCol, hFil, "% Aprobados", RGB(220, 220, 220), vbBlack, nombresColeccion
    
    leftPos = leftPos + wCol
    
    Dim sumM As Double, sumD As Double, sumA As Double, countEx As Long
    For col = 38 To 42
        If InStr(1, ws.Cells(2, col).Value, "Examen", vbTextCompare) > 0 And col < ultimaColExamen Then
            sumM = sumM + ws.Cells(4, col).Value: sumD = sumD + ws.Cells(6, col).Value
            sumA = sumA + ws.Cells(17, col).Value: countEx = countEx + 1
        End If
    Next col
    
    CrearColumnaDatos ws, leftPos, topPos, wCol, hFil, "Total Parciales", _
                      IIf(countEx > 0, Format(sumM / countEx, "0.00"), "-"), _
                      IIf(countEx > 0, Format(sumD / countEx, "0.00"), "-"), _
                      IIf(countEx > 0, Format(sumA / countEx, "0%"), "-"), _
                      RGB(0, 112, 192), RGB(91, 155, 213), nombresColeccion
    
    leftPos = leftPos + wCol
    
    For col = 38 To 42
        If InStr(1, ws.Cells(2, col).Value, "Examen", vbTextCompare) > 0 And col < ultimaColExamen Then
            CrearColumnaDatos ws, leftPos, topPos, wCol, hFil, ws.Cells(3, col).Value, _
                              Format(ws.Cells(4, col).Value, "0.00"), _
                              Format(ws.Cells(6, col).Value, "0.00"), _
                              Format(ws.Cells(17, col).Value, "0%"), _
                              RGB(0, 112, 192), RGB(221, 235, 247), nombresColeccion
            leftPos = leftPos + wCol
        End If
    Next col

    Dim sumMA As Double, sumDA As Double, sumAA As Double, countAct As Long
    For col = 38 To 42
        If InStr(1, ws.Cells(2, col).Value, "Prueba", vbTextCompare) > 0 Or InStr(1, ws.Cells(2, col).Value, "Actividad", vbTextCompare) > 0 Then
            sumMA = sumMA + ws.Cells(4, col).Value: sumDA = sumDA + ws.Cells(6, col).Value
            sumAA = sumAA + ws.Cells(17, col).Value: countAct = countAct + 1
        End If
    Next col
    
    CrearColumnaDatos ws, leftPos, topPos, wCol, hFil, "Total Actividades", _
                      IIf(countAct > 0, Format(sumMA / countAct, "0.00"), "-"), _
                      IIf(countAct > 0, Format(sumDA / countAct, "0.00"), "-"), _
                      IIf(countAct > 0, Format(sumAA / countAct, "0%"), "-"), _
                      RGB(31, 78, 47), RGB(0, 176, 80), nombresColeccion
    
    leftPos = leftPos + wCol
    
    For col = 38 To 42
        If InStr(1, ws.Cells(2, col).Value, "Prueba", vbTextCompare) > 0 Or InStr(1, ws.Cells(2, col).Value, "Actividad", vbTextCompare) > 0 Then
            CrearColumnaDatos ws, leftPos, topPos, wCol, hFil, ws.Cells(3, col).Value, _
                              Format(ws.Cells(4, col).Value, "0.00"), _
                              Format(ws.Cells(6, col).Value, "0.00"), _
                              Format(ws.Cells(17, col).Value, "0%"), _
                              RGB(31, 78, 47), RGB(146, 208, 80), nombresColeccion
            leftPos = leftPos + wCol
        End If
    Next col

    If ultimaColExamen > 0 Then
        CrearColumnaDatos ws, leftPos, topPos, wCol, hFil, "Examen Final", _
                          Format(ws.Cells(4, ultimaColExamen).Value, "0.00"), _
                          Format(ws.Cells(6, ultimaColExamen).Value, "0.00"), _
                          Format(ws.Cells(17, ultimaColExamen).Value, "0%"), _
                          RGB(80, 80, 80), RGB(255, 102, 0), nombresColeccion
    End If

    Dim arr() As String: ReDim arr(1 To nombresColeccion.count)
    For i = 1 To nombresColeccion.count: arr(i) = nombresColeccion(i): Next i
    
    Set shp = ws.Shapes.Range(arr).Group
    shp.Name = "TablaResumenFlotante"
    GenerarGraficoCajasyBigotesFinal
End Sub

Sub CrearCeldaFlotante(ws As Worksheet, L As Double, T As Double, w As Double, h As Double, txt As String, bgColor As Long, txtColor As Long, ByRef col As Collection)
    Dim s As Shape
    Set s = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, L, T, w, h)
    With s
        .Fill.ForeColor.RGB = bgColor
        .Line.ForeColor.RGB = vbWhite
        .Line.Weight = 1
        With .TextFrame2
            .TextRange.Text = txt
            .TextRange.Font.Size = 8
            .TextRange.Font.bold = True
            .TextRange.Font.Fill.ForeColor.RGB = txtColor
            .VerticalAnchor = msoAnchorMiddle
            .TextRange.ParagraphFormat.Alignment = msoAlignCenter
            .MarginLeft = 2: .MarginRight = 2
        End With
        col.Add .Name
    End With
End Sub

Sub CrearColumnaDatos(ws As Worksheet, L As Double, T As Double, w As Double, h As Double, tit As String, v1 As String, v2 As String, v3 As String, colorTit As Long, colorBody As Long, ByRef col As Collection)
    CrearCeldaFlotante ws, L, T, w, 40, tit, colorTit, vbWhite, col
    CrearCeldaFlotante ws, L, T + 40, w, h, v1, colorBody, vbBlack, col
    CrearCeldaFlotante ws, L, T + 40 + h, w, h, v2, colorBody, vbBlack, col
    CrearCeldaFlotante ws, L, T + 40 + (h * 2), w, h, v3, colorBody, vbBlack, col
End Sub

Sub GenerarGraficoCajasyBigotesFinal()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim col As Long, numItems As Long, i As Long
    Dim chtObj As ChartObject: Dim cht As Chart
    Dim sery As Series
    
    On Error Resume Next
    ws.ChartObjects("ContenedorGrafico").Delete
    On Error GoTo 0
    
    Dim medias() As Double, q1s() As Double, q3s() As Double, nombres() As String
    numItems = 0
    For col = 38 To 42
        If ws.Cells(3, col).Value <> "" Then
            numItems = numItems + 1
            ReDim Preserve nombres(1 To numItems): ReDim Preserve medias(1 To numItems)
            ReDim Preserve q1s(1 To numItems): ReDim Preserve q3s(1 To numItems)
            nombres(numItems) = ws.Cells(3, col).Value
            medias(numItems) = ws.Cells(4, col).Value
            q1s(numItems) = ws.Cells(12, col).Value
            q3s(numItems) = ws.Cells(13, col).Value
        End If
    Next col
    If numItems = 0 Then Exit Sub

    Dim rngDest As Range: Set rngDest = ws.Range("D18:G33")
    Set chtObj = ws.ChartObjects.Add(Left:=rngDest.Left, Top:=rngDest.Top, _
                                     Width:=rngDest.Width, Height:=rngDest.Height)
    chtObj.Name = "ContenedorGrafico"
    Set cht = chtObj.Chart
    
    With cht
        .ChartType = xlColumnClustered
        Set sery = .SeriesCollection.NewSeries
        sery.XValues = nombres
        sery.Values = medias
        
        With sery
            .Format.Fill.ForeColor.RGB = RGB(47, 117, 181)
            With .Format.Line
                .Visible = msoTrue
                .ForeColor.RGB = RGB(0, 51, 102)
                .Weight = 1.25
            End With
        End With
        
        .ChartGroups(1).GapWidth = 150
        .HasLegend = False
        
        With .Axes(xlValue)
            .MinimumScale = 0: .MaximumScale = 10: .MajorUnit = 1
            With .Format.Line
                .Visible = msoTrue
                .ForeColor.RGB = RGB(0, 0, 0)
                .Weight = 1.5
            End With
            .MajorGridlines.Format.Line.ForeColor.RGB = RGB(200, 200, 200)
        End With
        
        With .Axes(xlCategory)
            With .Format.Line
                .Visible = msoTrue
                .ForeColor.RGB = RGB(0, 0, 0)
                .Weight = 1.5
            End With
        End With
        
        .ChartArea.Format.Fill.Visible = msoTrue
        .ChartArea.Format.Fill.ForeColor.RGB = RGB(242, 242, 242)
        .PlotArea.Format.Fill.Visible = msoTrue
        .PlotArea.Format.Fill.ForeColor.RGB = RGB(242, 242, 242)
    End With

    With chtObj.ShapeRange
        .Line.ForeColor.RGB = RGB(0, 0, 0)
        .Line.Weight = 3
    End With

    cht.Refresh
    DoEvents
    
    Dim pLeft As Double, pTop As Double, pWidth As Double, pHeight As Double
    pLeft = cht.PlotArea.InsideLeft
    pTop = cht.PlotArea.InsideTop
    pWidth = cht.PlotArea.InsideWidth
    pHeight = cht.PlotArea.InsideHeight
    
    Dim y5 As Double: y5 = pTop + (pHeight * 0.5)
    Dim shpLinea5 As Shape
    Set shpLinea5 = cht.Shapes.AddLine(pLeft, y5, pLeft + pWidth, y5)
    
    With shpLinea5
        .ZOrder msoBringToFront
        With .Line
            .Visible = msoTrue
            .ForeColor.RGB = RGB(255, 0, 0)
            .Weight = 2.25
            .Transparency = 0
        End With
        .Shadow.Visible = msoFalse
    End With

    Dim xPos As Double, yQ1 As Double, yQ3 As Double
    For i = 1 To numItems
        xPos = pLeft + (pWidth / numItems) * (i - 0.5)
        yQ1 = pTop + pHeight * (1 - (q1s(i) / 10))
        yQ3 = pTop + pHeight * (1 - (q3s(i) / 10))
        
        With cht.Shapes.AddLine(xPos, yQ1, xPos, yQ3)
            .Line.ForeColor.RGB = RGB(0, 0, 0)
            .Line.Weight = 1.5
            .ZOrder msoBringToFront
        End With
        
        With cht.Shapes.AddLine(xPos - 6, yQ1, xPos + 6, yQ1)
            .Line.ForeColor.RGB = RGB(0, 0, 0)
            .Line.Weight = 1.5
            .ZOrder msoBringToFront
        End With
        
        With cht.Shapes.AddLine(xPos - 6, yQ3, xPos + 6, yQ3)
            .Line.ForeColor.RGB = RGB(0, 0, 0)
            .Line.Weight = 1.5
            .ZOrder msoBringToFront
        End With
    Next i

    ws.Range("D18").Select
    GenerarHistogramaCalificaciones
End Sub

Sub GenerarHistogramaCalificaciones()
    Dim wsOrigen As Worksheet
    Dim wsDestino As Worksheet: Set wsDestino = ActiveSheet
    Dim rngDatos As Range
    Dim celda As Range
    Dim frecuencias(1 To 10) As Long
    Dim etiquetas(1 To 10) As String
    Dim i As Long
    Dim nombreCompleto As String
    
    On Error Resume Next
    Set wsOrigen = Sheets("Notas")
    On Error GoTo 0
    
    If wsOrigen Is Nothing Then
        MsgBox "No se encontró la hoja llamada 'Notas'", vbCritical
        Exit Sub
    End If
    
    For i = 6 To 125
        If IsNumeric(wsDestino.Cells(i, 2).Value) And Not IsEmpty(wsDestino.Cells(i, 2)) Then
            
            nombreCompleto = WorksheetFunction.Trim(CStr(wsDestino.Cells(i, 1).Value))
            
            If UBound(Split(nombreCompleto, " ")) >= 2 Then
                Dim nota As Double: nota = wsDestino.Cells(i, 2).Value
                Dim grupo As Integer
                
                Select Case nota
                    Case 0 To 0.9999:    grupo = 1
                    Case 1 To 1.9999:    grupo = 2
                    Case 2 To 2.9999:    grupo = 3
                    Case 3 To 3.9999:    grupo = 4
                    Case 4 To 4.9999:    grupo = 5
                    Case 5 To 5.9999:    grupo = 6
                    Case 6 To 6.9999:    grupo = 7
                    Case 7 To 7.9999:    grupo = 8
                    Case 8 To 8.9999:    grupo = 9
                    Case 9 To 10:        grupo = 10
                End Select
                
                If grupo >= 1 And grupo <= 10 Then
                    frecuencias(grupo) = frecuencias(grupo) + 1
                End If
            End If
        End If
    Next i
    
    etiquetas(1) = "0-1": etiquetas(2) = "1-2": etiquetas(3) = "2-3"
    etiquetas(4) = "3-4": etiquetas(5) = "4-5": etiquetas(6) = "5-6"
    etiquetas(7) = "6-7": etiquetas(8) = "7-8": etiquetas(9) = "8-9"
    etiquetas(10) = "9-10"

    On Error Resume Next
    wsDestino.ChartObjects("HistogramaNotas").Delete
    On Error GoTo 0

    Dim chtObj As ChartObject
    Dim rngPos As Range: Set rngPos = wsDestino.Range("D35:G50")
    
    Set chtObj = wsDestino.ChartObjects.Add(Left:=rngPos.Left, Top:=rngPos.Top, _
                                            Width:=rngPos.Width, Height:=rngPos.Height)
    chtObj.Name = "HistogramaNotas"
    
    With chtObj.Chart
        .ChartType = xlColumnClustered
        .HasTitle = True: .ChartTitle.Text = "Histograma de Calificaciones Finales"

        Dim sery As Series: Set sery = .SeriesCollection.NewSeries
        
        With sery
            .XValues = etiquetas
            .Values = frecuencias
            
            Dim p As Integer
            For p = 1 To 10
                With .Points(p).Format.Fill
                    Select Case p
                        Case 1 To 3: .ForeColor.RGB = RGB(255, 180, 180)
                        Case 4 To 5: .ForeColor.RGB = RGB(255, 192, 0)
                        Case 6 To 7: .ForeColor.RGB = RGB(169, 208, 142)
                        Case Else:   .ForeColor.RGB = RGB(155, 194, 230)
                    End Select
                End With
                With .Points(p).Format.Line
                    .Visible = msoTrue
                    .ForeColor.RGB = RGB(0, 51, 102)
                    .Weight = 1
                End With
            Next p

            .HasDataLabels = True
            With .DataLabels
                .Format.TextFrame2.TextRange.Font.bold = msoTrue
                .Format.TextFrame2.TextRange.Font.Size = 10
                .Format.TextFrame2.TextRange.Font.Fill.ForeColor.RGB = RGB(40, 40, 40)
                .Position = xlLabelPositionOutsideEnd
            End With
        End With

        .ChartGroups(1).GapWidth = 10
        .HasLegend = False
        .ChartArea.Format.Fill.ForeColor.RGB = RGB(242, 242, 242)
        .PlotArea.Format.Fill.ForeColor.RGB = RGB(242, 242, 242)
        
        With .Axes(xlValue)
            .Format.Line.Visible = msoTrue
            .Format.Line.ForeColor.RGB = RGB(0, 0, 0)
            .MajorGridlines.Format.Line.ForeColor.RGB = RGB(210, 210, 210)
        End With
        
        With .Axes(xlCategory)
            .Format.Line.Visible = msoTrue
            .Format.Line.ForeColor.RGB = RGB(0, 0, 0)
        End With
    End With

    With chtObj.ShapeRange.Line
        .ForeColor.RGB = RGB(0, 0, 0)
        .Weight = 3
    End With

    wsDestino.Range("D38").Select
    GenerarGraficoDispersionCuadrantes
End Sub

Sub GenerarGraficoDispersionCuadrantes()
    Dim wsOrigen As Worksheet: Set wsOrigen = Sheets("Notas")
    Dim wsDestino As Worksheet: Set wsDestino = ActiveSheet
    Dim chtObj As ChartObject: Dim cht As Chart
    Dim i As Long, col As Long
    Dim colExamenes As Long, colActividades As Long
    Dim examenes() As Double, actividades() As Double
    Dim numAlumnos As Long
    
    colExamenes = 0: colActividades = 0
    For col = 4 To 8
        If UCase(wsOrigen.Cells(2, col).Value) Like "*EXAMEN*" Then colExamenes = col
        If UCase(wsOrigen.Cells(2, col).Value) Like "*PRUEBA COMPLEMENTARIA*" Then colActividades = col
    Next col
    
    If colExamenes = 0 Or colActividades = 0 Then
        MsgBox "No se han encontrado las columnas en la fila 2. Revisa que existan 'Examen' y 'Prueba Complementaria'.", vbExclamation
        Exit Sub
    End If
    
    numAlumnos = 0
    For i = 6 To 125
        If IsNumeric(wsOrigen.Cells(i, colExamenes).Value) And wsOrigen.Cells(i, colExamenes).Value <> "" And _
           IsNumeric(wsOrigen.Cells(i, colActividades).Value) And wsOrigen.Cells(i, colActividades).Value <> "" Then
            
            numAlumnos = numAlumnos + 1
            ReDim Preserve examenes(1 To numAlumnos)
            ReDim Preserve actividades(1 To numAlumnos)
            
            examenes(numAlumnos) = wsOrigen.Cells(i, colExamenes).Value
            actividades(numAlumnos) = wsOrigen.Cells(i, colActividades).Value
        End If
    Next i
    
    If numAlumnos = 0 Then Exit Sub

    On Error Resume Next
    wsDestino.ChartObjects("GraficoDispersion").Delete
    On Error GoTo 0

    Dim rngPos As Range: Set rngPos = wsDestino.Range("H18:M33")
    Set chtObj = wsDestino.ChartObjects.Add(Left:=rngPos.Left + 10, Top:=rngPos.Top, _
                                            Width:=rngPos.Width - 10, Height:=rngPos.Height)
    chtObj.Name = "GraficoDispersion"
    Set cht = chtObj.Chart
    
    With cht
        .ChartType = xlXYScatter
        With .SeriesCollection.NewSeries
            .XValues = examenes
            .Values = actividades
            .MarkerStyle = xlMarkerStyleCircle
            .MarkerSize = 7
            .Format.Fill.ForeColor.RGB = RGB(47, 117, 181)
            .Format.Line.Visible = msoFalse
        End With
        
        With .Axes(xlCategory)
            .MinimumScale = 0: .MaximumScale = 10: .MajorUnit = 1
            .HasTitle = True
            .AxisTitle.Text = "Media Exámenes (Teoría)"
        End With
        With .Axes(xlValue)
            .MinimumScale = 0: .MaximumScale = 10: .MajorUnit = 1
            .HasTitle = True
            .AxisTitle.Text = "Prueba Complementaria (Práctica)"
        End With
        
        .HasLegend = False
        .ChartArea.Format.Fill.ForeColor.RGB = RGB(242, 242, 242)
        .PlotArea.Format.Fill.ForeColor.RGB = RGB(242, 242, 242)
    End With

    cht.Refresh
    DoEvents
    
    Dim xVal5 As Double, yVal5 As Double
    xVal5 = cht.Axes(xlCategory).Left + (cht.Axes(xlCategory).Width / 2)
    yVal5 = cht.Axes(xlValue).Top + (cht.Axes(xlValue).Height / 2)
    
    Dim shpH As Shape
    Set shpH = cht.Shapes.AddLine(cht.PlotArea.InsideLeft, yVal5, _
                                  cht.PlotArea.InsideLeft + cht.PlotArea.InsideWidth, yVal5)
    With shpH
        .ZOrder msoBringToFront
        With .Line
            .Visible = msoTrue
            .ForeColor.RGB = RGB(255, 0, 0)
            .Weight = 2
            .DashStyle = msoLineDash
            .Transparency = 0
        End With
        .Shadow.Visible = msoFalse
    End With
    
    Dim shpV As Shape
    Set shpV = cht.Shapes.AddLine(xVal5, cht.PlotArea.InsideTop, _
                                  xVal5, cht.PlotArea.InsideTop + cht.PlotArea.InsideHeight)
    With shpV
        .ZOrder msoBringToFront
        With .Line
            .Visible = msoTrue
            .ForeColor.RGB = RGB(255, 0, 0)
            .Weight = 2
            .DashStyle = msoLineDash
            .Transparency = 0
        End With
        .Shadow.Visible = msoFalse
    End With
    Dim shpDiag As Shape
    
    Dim xCero As Double: xCero = cht.PlotArea.InsideLeft
    Dim yCero As Double: yCero = cht.PlotArea.InsideTop + cht.PlotArea.InsideHeight
    Dim xFinal As Double: xFinal = xCero + cht.PlotArea.InsideWidth
    Dim yFinal As Double: yFinal = cht.PlotArea.InsideTop
    
    Set shpDiag = cht.Shapes.AddLine(xCero, yCero, xFinal, yFinal)
    
    With shpDiag
        .ZOrder msoBringToFront
        With .Line
            .Visible = msoTrue
            .ForeColor.RGB = RGB(0, 0, 0)
            .Weight = 1.5
            .DashStyle = msoLineDash
            .Transparency = 0
        End With
        .Shadow.Visible = msoFalse
