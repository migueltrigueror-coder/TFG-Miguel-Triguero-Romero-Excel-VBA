Sub IdentificarTopBottomAlumnos()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim i As Long, lastRow As Long
    Dim nombre As String, nota As Variant
    Dim contadorValidos As Long: contadorValidos = 0
    
    lastRow = ws.Cells(ws.Rows.count, "A").End(xlUp).Row
    
    Dim listaNombres() As String
    Dim listaNotas() As Double
    
    For i = 6 To lastRow
        nombre = WorksheetFunction.Trim(ws.Cells(i, "A").Value)
        nota = ws.Cells(i, "B").Value
        
        If IsNumeric(nota) And nota <> "" Then
            Dim partes As Variant
            partes = Split(nombre, " ")
            
            If UBound(partes) >= 2 Then
                contadorValidos = contadorValidos + 1
                ReDim Preserve listaNombres(1 To contadorValidos)
                ReDim Preserve listaNotas(1 To contadorValidos)
                listaNombres(contadorValidos) = nombre
                listaNotas(contadorValidos) = CDbl(nota)
            End If
        End If
    Next i
    
    If contadorValidos = 0 Then
        MsgBox "No se encontraron alumnos válidos.", vbExclamation
        Exit Sub
    End If

    Dim j As Long, tN As Double, tS As String
    For i = 1 To contadorValidos - 1
        For j = i + 1 To contadorValidos
            If listaNotas(i) < listaNotas(j) Then
                tN = listaNotas(i): listaNotas(i) = listaNotas(j): listaNotas(j) = tN
                tS = listaNombres(i): listaNombres(i) = listaNombres(j): listaNombres(j) = tS
            End If
        Next j
    Next i

    Dim colTable As Integer: colTable = 9
    Dim filaInicio As Integer: filaInicio = 35
    
    ws.Range("H35:M50").Clear
    ws.Range("H35:M50").UnMerge
    
    With ws.Range(ws.Cells(filaInicio, colTable), ws.Cells(filaInicio + 1, colTable + 4))
        .Merge
        .Value = "5 ALUMNOS CON LAS CALIFICACIONES MÁS ALTAS"
        .Interior.Color = RGB(68, 114, 196)
        .Font.Color = RGB(255, 255, 255)
        .Font.bold = True
        .Font.Size = 12
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .WrapText = True
    End With
    
    Dim nTop As Integer: nTop = IIf(contadorValidos < 5, contadorValidos, 5)
    For i = 1 To nTop
        With ws.Cells(filaInicio + 1 + i, colTable).Resize(1, 4)
            .Merge
            .Value = listaNombres(i)
            .HorizontalAlignment = xlCenter
            .VerticalAlignment = xlCenter
        End With
        With ws.Cells(filaInicio + 1 + i, colTable + 4)
            .Value = listaNotas(i)
            .HorizontalAlignment = xlCenter
            .Font.bold = True
        End With
        
        With ws.Cells(filaInicio + 1 + i, colTable).Resize(1, 5)
            .Interior.Color = RGB(169, 208, 142)
            .Borders.Color = RGB(255, 255, 255)
            .Borders.Weight = xlThin
        End With
    Next i
    
    Dim filaBotHeader As Integer: filaBotHeader = filaInicio + nTop + 4
    
    With ws.Range(ws.Cells(filaBotHeader, colTable), ws.Cells(filaBotHeader + 1, colTable + 4))
        .Merge
        .Value = "5 ALUMNOS CON LAS CALIFICACIONES MÁS BAJAS"
        .Interior.Color = RGB(68, 114, 196)
        .Font.Color = RGB(255, 255, 255)
        .Font.bold = True
        .Font.Size = 12
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .WrapText = True
    End With
    
    Dim n As Integer: n = 1
    Dim startIdx As Long: startIdx = contadorValidos
    Dim endIdx As Long: endIdx = IIf(contadorValidos - 4 < nTop + 1, nTop + 1, contadorValidos - 4)

    If startIdx >= endIdx Then
        For i = startIdx To endIdx Step -1
            With ws.Cells(filaBotHeader + 1 + n, colTable).Resize(1, 4)
                .Merge
                .Value = listaNombres(i)
                .HorizontalAlignment = xlCenter
                .VerticalAlignment = xlCenter
            End With
            With ws.Cells(filaBotHeader + 1 + n, colTable + 4)
                .Value = listaNotas(i)
                .HorizontalAlignment = xlCenter
                .Font.bold = True
            End With
            
            With ws.Cells(filaBotHeader + 1 + n, colTable).Resize(1, 5)
                .Interior.Color = RGB(244, 177, 131)
                .Borders.Color = RGB(255, 255, 255)
                .Borders.Weight = xlThin
            End With
            n = n + 1
        Next i
    End If

    ws.Range("I42:M70").Font.Size = 11
    GenerarTablaDudosos
End Sub

Sub GenerarTablaDudosos()
    Dim wsOrigen As Worksheet
    Dim wsDestino As Worksheet
    Dim col As Long
    Dim i As Long
    Dim lastRow As Long
    Dim leftPos As Double
    Dim topPos As Double
    Dim nombresColeccion As New Collection
    Dim shp As Shape
    
    Set wsOrigen = Sheets("Notas")
    Set wsDestino = ActiveSheet
    
    On Error Resume Next
    wsDestino.Shapes("TablaDudososFlotante").Delete
    On Error GoTo 0
    
    leftPos = wsDestino.Range("D52").Left
    topPos = wsDestino.Range("D52").Top
    
    Dim wNom As Double: wNom = 200
    Dim wDat As Double: wDat = 100
    Dim hCab As Double: hCab = 50
    Dim hFil As Double: hFil = 32
    Dim anchoTotal As Double: anchoTotal = wNom + (wDat * 4)
    
    DibujarCeldaRevision_Plana wsDestino, leftPos, topPos, anchoTotal, 45, _
                       "ALUMNOS EN REVISIÓN (NOTAS 4.5 - 4.9)", RGB(68, 114, 196), RGB(255, 255, 255), nombresColeccion, True, 16
    
    topPos = topPos + 45
    DibujarCeldaRevision_Plana wsDestino, leftPos, topPos, wNom, hCab, "Nombre del alumno", RGB(217, 225, 242), RGB(0, 0, 0), nombresColeccion, True, 12
    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom, topPos, wDat, hCab, "Nota media final", RGB(217, 225, 242), RGB(0, 0, 0), nombresColeccion, True, 12
    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom + wDat, topPos, wDat, hCab, "Media exámenes", RGB(217, 225, 242), RGB(0, 0, 0), nombresColeccion, True, 12
    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom + (wDat * 2), topPos, wDat, hCab, "Media actividades", RGB(217, 225, 242), RGB(0, 0, 0), nombresColeccion, True, 12
    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom + (wDat * 3), topPos, wDat, hCab, "Impacto actividades", RGB(217, 225, 242), RGB(0, 0, 0), nombresColeccion, True, 12
    
    Dim colsEx As New Collection: Dim colsPr As New Collection
    For col = 1 To wsOrigen.Cells(2, wsOrigen.Columns.count).End(xlToLeft).Column
        Dim cab As String: cab = UCase(wsOrigen.Cells(2, col).Value)
        If cab Like "*EXAMEN*" Then
            colsEx.Add col
        ElseIf cab Like "*PRUEBA*" Or cab Like "*ACTIVIDAD*" Then
            colsPr.Add col
        End If
    Next col

    lastRow = wsOrigen.Cells(wsOrigen.Rows.count, 9).End(xlUp).Row
    Dim filaActualPos As Double: filaActualPos = topPos + hCab
    Dim contador As Integer: contador = 0
    
    For i = 6 To lastRow
        Dim notaFinal As Variant: notaFinal = wsOrigen.Cells(i, 9).Value
        Dim nombreCompleto As String: nombreCompleto = WorksheetFunction.Trim(CStr(wsOrigen.Cells(i, 3).Value))
        
        If IsNumeric(notaFinal) Then
            If notaFinal >= 4.5 And notaFinal <= 4.9 Then
                If UBound(Split(nombreCompleto, " ")) >= 2 Then
                    contador = contador + 1
                    
                    Dim sEx As Double: sEx = 0: Dim cEx As Integer: cEx = 0: Dim v As Variant
                    For Each v In colsEx: If IsNumeric(wsOrigen.Cells(i, v).Value) Then sEx = sEx + wsOrigen.Cells(i, v).Value: cEx = cEx + 1
                    Next v
                    Dim sPr As Double: sPr = 0: Dim cPr As Integer: cPr = 0
                    For Each v In colsPr: If IsNumeric(wsOrigen.Cells(i, v).Value) Then sPr = sPr + wsOrigen.Cells(i, v).Value: cPr = cPr + 1
                    Next v
                    
                    DibujarCeldaRevision_Plana wsDestino, leftPos, filaActualPos, wNom, hFil, nombreCompleto, RGB(255, 255, 255), RGB(0, 0, 0), nombresColeccion, False, 11
                    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom, filaActualPos, wDat, hFil, Format(notaFinal, "0.00"), RGB(255, 255, 255), RGB(0, 0, 0), nombresColeccion, False, 11
                    
                    Dim tEx As String: tEx = IIf(cEx > 0, Format(sEx / cEx, "0.00"), "-")
                    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom + wDat, filaActualPos, wDat, hFil, tEx, RGB(255, 255, 255), RGB(0, 0, 0), nombresColeccion, False, 11
                    
                    Dim tPr As String: tPr = IIf(cPr > 0, Format(sPr / cPr, "0.00"), "-")
                    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom + (wDat * 2), filaActualPos, wDat, hFil, tPr, RGB(255, 255, 255), RGB(0, 0, 0), nombresColeccion, False, 11
                    
                    Dim valorImp As Variant: Dim colImp As Long: Dim txtImp As String
                    If IsError(wsOrigen.Cells(i, 20).Value) Then
                        txtImp = "Err": colImp = RGB(0, 0, 0)
                    Else
                        valorImp = wsOrigen.Cells(i, 20).Value
                        If IsNumeric(valorImp) And valorImp <> "" Then
                            txtImp = IIf(valorImp > 0, "+", "") & Format(valorImp, "0.00")
                            colImp = IIf(valorImp >= 0, RGB(0, 128, 0), RGB(200, 0, 0))
                        Else
                            txtImp = "-": colImp = RGB(0, 0, 0)
                        End If
                    End If
                    DibujarCeldaRevision_Plana wsDestino, leftPos + wNom + (wDat * 3), filaActualPos, wDat, hFil, txtImp, RGB(255, 255, 255), colImp, nombresColeccion, True, 11
                    
                    filaActualPos = filaActualPos + hFil
                End If
            End If
        End If
        If contador >= 30 Then Exit For
    Next i
    
    If nombresColeccion.count > 0 Then
        Dim arr() As String: ReDim arr(1 To nombresColeccion.count)
        For i = 1 To nombresColeccion.count: arr(i) = nombresColeccion(i): Next i
        Set shp = wsDestino.Shapes.Range(arr).Group
        shp.Name = "TablaDudososFlotante"
        shp.Shadow.Visible = msoFalse
    End If
End Sub

Private Sub DibujarCeldaRevision_Plana(ws As Worksheet, x As Double, y As Double, w As Double, h As Double, _
                               txt As String, bColor As Long, tColor As Long, _
                               ByRef colNames As Collection, IsBold As Boolean, FontSize As Integer)
    Dim sName As String: sName = "DudCell_" & Timer & "_" & (colNames.count + 1)
    Dim shpCelda As Shape
    Set shpCelda = ws.Shapes.AddShape(1, x, y, w, h)
    
    With shpCelda
        .Name = sName
        .Shadow.Visible = msoFalse
        With .TextFrame2.TextRange
            .Text = txt
            .Font.Size = FontSize
            .Font.bold = IIf(IsBold, msoTrue, msoFalse)
            .Font.Fill.ForeColor.RGB = tColor
            .ParagraphFormat.Alignment = 2
        End With
        .TextFrame2.VerticalAnchor = 3
        .Fill.ForeColor.RGB = bColor
        .Line.ForeColor.RGB = RGB(160, 160, 160)
        .Line.Weight = 1
    End With
    colNames.Add sName
    GenerarInformeFinal
End Sub

Sub GenerarInformeFinal()
    Dim ws As Worksheet
    Set ws = ActiveSheet
    Dim wsOrigen As Worksheet
    Set wsOrigen = Sheets("Notas")
    Dim shp As Shape
    Dim txtFinal As String
    Dim rngPosicion As Range
    Set rngPosicion = ws.Range("O5:X50")
    
    Dim NombreAsignatura As String
    NombreAsignatura = wsOrigen.Range("E1").Value
    
    Dim CursoAcademico As String
    CursoAcademico = wsOrigen.Range("C1").Value
    
    Dim totalMatriculados As Long
    totalMatriculados = 0
    Dim numNP As Long
    numNP = 0
    Dim numReconocimientos As Long
    numReconocimientos = 0
    Dim numAprobadosPrevios As Long
    numAprobadosPrevios = 0
    
    Dim i As Long
    Dim ultimaFila As Long
    Dim n As Long
    n = 0
    Dim nombreCompleto As String
    Dim valorNota As String
    Dim notas() As Double
    
    ultimaFila = ws.Cells(ws.Rows.count, "A").End(xlUp).Row
    If ultimaFila < 6 Then
        ultimaFila = 6
    End If

    For i = 6 To ultimaFila
        If Trim(CStr(ws.Cells(i, 2).Value)) <> "" Then
            valorNota = UCase(Trim(CStr(ws.Cells(i, 2).Value)))
            nombreCompleto = Trim(CStr(ws.Cells(i, 1).Value))
            
            Do While InStr(nombreCompleto, "  ") > 0
                nombreCompleto = Replace(nombreCompleto, "  ", " ")
            Loop
            
            If UBound(Split(nombreCompleto, " ")) >= 2 Then
                totalMatriculados = totalMatriculados + 1
                
                If IsNumeric(ws.Cells(i, 2).Value) Then
                    ReDim Preserve notas(n)
                    notas(n) = CDbl(ws.Cells(i, 2).Value)
                    n = n + 1
                Else
                    Select Case valorNota
                        Case "NP"
                            numNP = numNP + 1
                        Case "RECONOCIMIENTO CRÉDITOS"
                            numReconocimientos = numReconocimientos + 1
                        Case "APROBADO EN OTRO CURSO"
                            numAprobadosPrevios = numAprobadosPrevios + 1
                    End Select
                End If
            End If
        End If
    Next i

    Dim valMedia As Double, valMediana As Double, valDesv As Double, valCV As Double
    Dim Q1 As Double, Q3 As Double, valMin As Double, valMax As Double, valIQR As Double
    Dim valRango As Double, valP10 As Double, valP90 As Double
    Dim valAsimetria As Double, valCurtosis As Double, valMediaRecortada As Double
    Dim cantAprobados As Long, cantSuspensos As Long, sumaNotasSuspensos As Double, mediaSuspensos As Double
    Dim porcAprobados As Double, porcSuspensos As Double
    
    If n > 0 Then
        valMedia = WorksheetFunction.Average(notas)
        valMediana = WorksheetFunction.Median(notas)
        valDesv = WorksheetFunction.StDev_P(notas)
        valCV = IIf(valMedia <> 0, valDesv / valMedia, 0)
        Q1 = WorksheetFunction.Quartile_Inc(notas, 1)
        Q3 = WorksheetFunction.Quartile_Inc(notas, 3)
        valMin = WorksheetFunction.Min(notas)
        valMax = WorksheetFunction.Max(notas)
        valIQR = Q3 - Q1
        valRango = valMax - valMin
        valP10 = WorksheetFunction.Percentile_Inc(notas, 0.1)
        valP90 = WorksheetFunction.Percentile_Inc(notas, 0.9)
        valAsimetria = WorksheetFunction.Skew(notas)
        valCurtosis = WorksheetFunction.Kurt(notas)
        valMediaRecortada = WorksheetFunction.TrimMean(notas, 0.1)
        
        cantAprobados = 0
        cantSuspensos = 0
        sumaNotasSuspensos = 0
        For i = 0 To UBound(notas)
            If notas(i) >= 5 Then
                cantAprobados = cantAprobados + 1
            Else
                cantSuspensos = cantSuspensos + 1
                sumaNotasSuspensos = sumaNotasSuspensos + notas(i)
            End If
        Next i
        
        porcAprobados = cantAprobados / n
        porcSuspensos = cantSuspensos / n
        mediaSuspensos = IIf(cantSuspensos > 0, sumaNotasSuspensos / cantSuspensos, 0)
    End If

    Dim col As Long, sumaMediaEx As Double, sumaSDEx As Double, contEx As Long
    Dim mediaBloqueEx As Double, sdBloqueEx As Double
    Dim sumaAprobEx As Double, porcAprobadosEx As Double
    Dim primeraMediaEx As Double, ultimaMediaEx As Double, varMediaEx As Double
    Dim sumaDificultadEx As Double, sumaDiscriminacionEx As Double
    Dim mediaDificultadEx As Double, mediaDiscriminacionEx As Double
    
    Dim sumaMediaAct As Double, sumaSDAct As Double, contAct As Long
    Dim mediaBloqueAct As Double, sdBloqueAct As Double, cvBloqueAct As Double
    Dim primeraMediaAct As Double, ultimaMediaAct As Double, varMediaAct As Double
    
    Dim primeraMediaGlobal As Double, ultimaMediaGlobal As Double, contGlobal As Long
    
    For col = 38 To 41
        If ws.Cells(4, col).Value <> "" Then
            If contGlobal = 0 Then
                primeraMediaGlobal = ws.Cells(4, col).Value
            End If
            ultimaMediaGlobal = ws.Cells(4, col).Value
            contGlobal = contGlobal + 1
            
            If InStr(1, ws.Cells(2, col).Value, "Examen", vbTextCompare) > 0 Then
                sumaMediaEx = sumaMediaEx + ws.Cells(4, col).Value
                sumaSDEx = sumaSDEx + ws.Cells(6, col).Value
                sumaAprobEx = sumaAprobEx + ws.Cells(17, col).Value
                sumaDificultadEx = sumaDificultadEx + ws.Cells(22, col).Value
                sumaDiscriminacionEx = sumaDiscriminacionEx + ws.Cells(21, col).Value
                If contEx = 0 Then
                    primeraMediaEx = ws.Cells(4, col).Value
                End If
                ultimaMediaEx = ws.Cells(4, col).Value
                contEx = contEx + 1
            End If
            
            If InStr(1, ws.Cells(2, col).Value, "Prueba Complementaria", vbTextCompare) > 0 Or InStr(1, ws.Cells(2, col).Value, "Actividad", vbTextCompare) > 0 Then
                sumaMediaAct = sumaMediaAct + ws.Cells(4, col).Value
                sumaSDAct = sumaSDAct + ws.Cells(6, col).Value
                If contAct = 0 Then
                    primeraMediaAct = ws.Cells(4, col).Value
                End If
                ultimaMediaAct = ws.Cells(4, col).Value
                contAct = contAct + 1
            End If
        End If
    Next col
    
    If contEx > 0 Then
        mediaBloqueEx = sumaMediaEx / contEx
        sdBloqueEx = sumaSDEx / contEx
        porcAprobadosEx = sumaAprobEx / contEx
        varMediaEx = ultimaMediaEx - primeraMediaEx
        mediaDificultadEx = sumaDificultadEx / contEx
        mediaDiscriminacionEx = sumaDiscriminacionEx / contEx
    End If
    
    If contAct > 0 Then
        mediaBloqueAct = sumaMediaAct / contAct
        sdBloqueAct = sumaSDAct / contAct
        cvBloqueAct = IIf(mediaBloqueAct <> 0, sdBloqueAct / mediaBloqueAct, 0)
        varMediaAct = ultimaMediaAct - primeraMediaAct
    End If

    Dim diagMediana As String
    If Round(valMedia, 2) > Round(valMediana, 2) Then
        diagMediana = "hay un grupo reducido de alumnos con calificaciones muy altas que están elevando la media por encima del rendimiento general de la clase."
    ElseIf Round(valMedia, 2) < Round(valMediana, 2) Then
        diagMediana = "hay un grupo de alumnos con calificaciones muy bajas que están penalizando la media, ocultando un rendimiento general algo superior."
    Else
        diagMediana = "existe una distribución simétrica y equilibrada, siendo la media un reflejo muy fiel del rendimiento general del aula."
    End If

    Dim nivelDispersion As String
    If valCV < 0.15 Then
        nivelDispersion = "bajo"
    ElseIf valCV <= 0.3 Then
        nivelDispersion = "moderado"
    Else
        nivelDispersion = "alto"
    End If

    Dim diagIQR As String
    If valIQR < 2.5 Then
        diagIQR = "este estrecho margen de notas confirma que el grupo es muy compacto y avanza a un ritmo muy similar, sin apenas distancias significativas entre el rendimiento de unos alumnos y otros."
    ElseIf valIQR <= 4 Then
        diagIQR = "esta dispersión se considera habitual y equilibrada, reflejando una distribución del rendimiento normal y coherente con los objetivos de la asignatura."
    Else
        diagIQR = "existe una brecha importante en el aula; este valor revela una distancia crítica entre el alumnado que ha asimilado con éxito los conceptos básicos y aquellos que se han quedado significativamente rezagados."
    End If

    Dim diagP10 As String
    If valP10 < 2.5 Then
        diagP10 = "lo que indica que el 10% del alumnado está en una situación de riesgo crítico, con calificaciones muy alejadas del aprobado que sugieren una posible desconexión o falta de base previa."
    ElseIf valP10 < 4 Then
        diagP10 = "lo que indica que el 10% del alumnado con mayores dificultades se sitúa todavía a cierta distancia del aprobado, aunque dentro de un margen recuperable. Este resultado sugiere la existencia de un grupo con carencias relevantes en la asimilación de los contenidos, pero que podría mejorar su rendimiento mediante refuerzo académico y seguimiento tutorial."
    ElseIf valP10 < 4.9 Then
        diagP10 = "lo que muestra que incluso los alumnos con más dificultades están cerca del aprobado, indicando que el nivel mínimo de la clase es aceptable y recuperable con tutorías."
    Else
        diagP10 = "lo que muestra un nivel de rendimiento mínimo sólido en la totalidad del grupo."
    End If

    Dim diagP90 As String
    If valP90 > 8.5 Then
        diagP90 = "destacando la presencia de un grupo de excelencia con un rendimiento sobresaliente que lidera la progresión del curso."
    ElseIf valP90 >= 6.5 Then
        diagP90 = "lo que refleja la presencia de un grupo de alumnos con rendimiento alto dentro de la asignatura, aunque sin alcanzar niveles de excelencia extrema. Este valor sugiere una distribución equilibrada en la parte superior de la clase, con varios estudiantes consolidando un dominio sólido de los contenidos."
    Else
        diagP90 = "lo que sugiere que incluso los mejores alumnos han tenido dificultades para alcanzar notas de excelencia, pudiendo indicar un nivel de exigencia muy alto o pruebas excesivamente complejas."
    End If

    Dim diagExito As String
    If porcAprobados > 0.65 Then
        diagExito = "En términos generales, esta tasa de éxito del |" & Format(porcAprobados, "0%") & "| se considera un indicador muy positivo y saludable para el nivel de exigencia de la asignatura."
    ElseIf porcAprobados >= 0.5 Then
        diagExito = "En términos generales, esta tasa de éxito del |" & Format(porcAprobados, "0%") & "| puede considerarse aceptable dentro de los estándares habituales de la asignatura, reflejando un equilibrio razonable entre nivel de exigencia y grado de superación por parte del alumnado."
    Else
        diagExito = "En términos generales, una tasa de éxito inferior al 50% resulta alarmante y sugiere la necesidad de revisar los criterios de evaluación o el nivel de dificultad de las pruebas principales."
    End If

    Dim diagSuspensos As String
    If mediaSuspensos > 4 Then
        diagSuspensos = "La nota media entre los suspensos, superior a 4.0, indica que una parte significativa del alumnado ha quedado muy cerca de alcanzar el aprobado. Este resultado sugiere que existe un margen razonable para recuperar a estos estudiantes mediante acciones específicas de refuerzo y seguimiento académico."
    ElseIf mediaSuspensos >= 3 Then
        diagSuspensos = "Una media de suspensos situada entre 3.0 y 4.0 indica que la mayoría del alumnado no apto se encuentra a una distancia moderada del aprobado. Este perfil sugiere que un número relevante de estudiantes aún no ha consolidado adecuadamente los conceptos básicos de la asignatura, lo que podría dificultar la superación de la materia sin medidas de refuerzo adicionales."
    Else
        diagSuspensos = "Una media de suspensos inferior a 3.0 indica que el conjunto del alumnado no apto puede presentar deficiencias de base importantes (posible abandono o carencias formativas previas), y que no se trata de casos fácilmente recuperables mediante intervenciones puntuales. En este escenario resulta recomendable identificar subgrupos específicos y plantear medidas más estructuradas de apoyo académico."
    End If

    Dim diagAsim As String
    If valAsimetria > 0.5 Then
        diagAsim = "El histograma muestra una mayor concentración de alumnos en las calificaciones bajas o medias y una cola menos frecuente hacia las notas altas. Este patrón puede deberse a mayor dificultad en algunos ítems, carencias previas en parte del alumnado o a la presencia de un grupo reducido con calificaciones elevadas."
    ElseIf valAsimetria < -0.5 Then
        diagAsim = "El histograma muestra concentración en las calificaciones altas, con pocos suspensos relativos. Esto puede indicar buen dominio general de la materia o, alternativamente, que las pruebas no han sido suficientemente discriminativas en la parte alta."
    Else
        diagAsim = "La distribución es aproximadamente simétrica: la proporción de alumnos destacados por encima de la media es comparable a la de alumnos rezagados por debajo. Esto suele corresponder a un comportamiento equilibrado del grupo."
    End If

    Dim diagKurt As String
    If valKurtosis > 0.5 Then
        diagKurt = "el valor de la curtosis dibuja un perfil muy concentrado en torno a la media, lo que confirma que estamos ante un grupo que avanza en bloque, con un nivel de asimilación de conocimientos muy similar entre casi todos los estudiantes."
    ElseIf valKurtosis < -0.5 Then
        diagKurt = "esta curtosis baja dibuja un perfil más plano evidenciando una gran diversidad de niveles en el aula. Las calificaciones están muy repartidas a lo largo de todo el espectro (del 0 al 10), sin un grupo mayoritario claro."
    Else
        diagKurt = "el valor de la curtosis muestra una concentración estándar de alumnos alrededor del promedio, dibujando la habitual forma de campana esperable en un grupo de este tamaño."
    End If

    Dim diagRecortada As String
    If valMediaRecortada > (valMedia + 0.05) Then
        diagRecortada = "La media recortada es superior a la media global, lo que confirma que las calificaciones más bajas (suspensos severos o ceros) estaban penalizando el promedio general del grupo."
    ElseIf valMediaRecortada < (valMedia - 0.05) Then
        diagRecortada = "La media recortada es inferior a la media global, lo que indica que las calificaciones más altas (sobresalientes) estaban inflando el promedio por encima del rendimiento del núcleo central de la clase."
    Else
        diagRecortada = "La media recortada es prácticamente idéntica a la media global, lo que sugiere que no hay valores extremos significativos que distorsionen el promedio del grupo."
    End If

    Dim diagBloqueEx As String
    If sdBloqueEx > (valDesv * 1.1) Then
        diagBloqueEx = "La desviación estándar del bloque de exámenes (SD = |" & Format(sdBloqueEx, "0.00") & "|) supera notablemente la desviación estándar global (SD global = |" & Format(valDesv, "0.00") & "|), lo que indica una mayor dispersión en el rendimiento de las pruebas teóricas."
    ElseIf sdBloqueEx < (valDesv * 0.9) Then
        diagBloqueEx = "La desviación estándar del bloque de exámenes (SD = |" & Format(sdBloqueEx, "0.00") & "|) es menor que la desviación estándar global (SD global = |" & Format(valDesv, "0.00") & "|), indicando que el rendimiento en las pruebas teóricas ha sido más uniforme que el resultado final."
    Else
        diagBloqueEx = "La desviación estándar del bloque de exámenes (SD = |" & Format(sdBloqueEx, "0.00") & "|) es similar a la desviación estándar global (SD global = |" & Format(valDesv, "0.00") & "|), mostrando un comportamiento de dispersión comparable al de la nota final."
    End If

    Dim txtDificultad As String
    If mediaDificultadEx < 0.5 Then
        txtDificultad = "indicando que han resultado difíciles; un reto exigente para la mayoría de los alumnos."
    ElseIf mediaDificultadEx <= 0.75 Then
        txtDificultad = "indicando una dificultad media, muy equilibrada para el nivel del curso."
    Else
        txtDificultad = "indicando que han resultado sencillos, con un alto grado de asimilación de los contenidos básicos."
    End If
    
    Dim txtDiscriminacion As String
    If mediaDiscriminacionEx > 0.4 Then
        txtDiscriminacion = "lo que evidencia una capacidad de discriminación alta, distinguiendo con gran precisión a los alumnos según su nivel de preparación."
    ElseIf mediaDiscriminacionEx >= 0.2 Then
        txtDiscriminacion = "lo que evidencia una capacidad de discriminación adecuada para los objetivos de la asignatura."
    Else
        txtDiscriminacion = "lo que evidencia una capacidad limitada; el examen no ha permitido diferenciar claramente entre los distintos niveles de competencia."
    End If

    Dim txtAnalisisTendenciaEx As String
    If varMediaEx > 0.4 Then
        txtAnalisisTendenciaEx = "observándose una tendencia ascendente que sugiere una mejor adaptación del alumnado a la materia."
    ElseIf varMediaEx < -0.4 Then
        txtAnalisisTendenciaEx = "observándose una tendencia descendente, lo que podría indicar un aumento de la complejidad o fatiga en el grupo."
    Else
        txtAnalisisTendenciaEx = "observándose una tendencia estable en el rendimiento durante todo el periodo lectivo."
    End If
    
    Dim txtAnalisisVariacionEx As String
    If varMediaEx >= 0.6 Then
        txtAnalisisVariacionEx = "una mejora significativa del rendimiento (|" & Format(varMediaEx, "0.0") & " puntos|)."
    ElseIf varMediaEx <= -0.6 Then
        txtAnalisisVariacionEx = "un descenso relevante del rendimiento (|" & Format(varMediaEx, "0.0") & " puntos|)."
    Else
        txtAnalisisVariacionEx = "una variación moderada (|" & Format(varMediaEx, "0.0") & " puntos|)."
    End If

    Dim diagDispersionAct As String
    If cvBloqueAct < 0.15 Then
        diagDispersionAct = "lo que refleja una alta homogeneidad en el trabajo continuo; la gran mayoría del alumnado cumple con las actividades complementarias evidenciando un nivel de desempeño e implicación muy similar."
    ElseIf cvBloqueAct <= 0.3 Then
        diagDispersionAct = "lo que indica una dispersión moderada, mostrando variaciones esperables en la calidad de las entregas que dependen del compromiso o destreza individual de cada estudiante."
    Else
        diagDispersionAct = "lo que evidencia una alta heterogeneidad en la evaluación continua, sugiriendo una fuerte polarización entre alumnos muy implicados en las actividades complementarias y otros con entregas deficientes o no presentadas."
    End If

    Dim difActEx As Double
    difActEx = mediaBloqueAct - mediaBloqueEx
    
    Dim diagDifActEx As String
    If difActEx > 0.5 Then
        diagDifActEx = "lo que indica que el alumnado rinde significativamente mejor en la evaluación continua. Este patrón estadístico, visible en la nube de puntos del Gráfico de Correlación, sugiere que las tareas guiadas actúan como un factor de éxito y compensación frente a la mayor exigencia o presión de las pruebas objetivas."
    ElseIf difActEx < -0.5 Then
        diagDifActEx = "lo que indica que el alumnado rinde peor en las actividades complementarias que en las pruebas teóricas. Este déficit muestra que el alumnado no ha entendido o no ha trabajado suficiente en las actividades complementarias de evaluación."
    Else
        diagDifActEx = "lo que revela un rendimiento equilibrado en ambos formatos evaluativos. Esta simetría confirma una alta coherencia en el diseño de la asignatura, demostrando que la asimilación teórica y la ejecución práctica de los alumnos avanzan en paralelo."
    End If

    Dim diagTendenciaAct As String
    If varMediaAct > 0.4 Then
        diagTendenciaAct = "progresiva, lo que evidencia un aumento en el compromiso o en la destreza del alumno a medida que avanzaba el programa."
    ElseIf varMediaAct < -0.4 Then
        diagTendenciaAct = "irregular, lo que podría sugerir que el interés o la dificultad de las tareas ha sido muy variable a lo largo del curso."
    Else
        diagTendenciaAct = "estable, lo que refleja una regularidad constante en el trabajo semanal del grupo."
    End If

    Dim diagComparativaFinal As String
    If mediaBloqueAct > (mediaBloqueEx + 1) Then
        diagComparativaFinal = "sugiere que la evaluación continua actúa como un elemento compensador, siendo la clave para que muchos alumnos alcancen el aprobado a pesar de las dificultades en los exámenes."
    ElseIf mediaBloqueAct < mediaBloqueEx Then
        diagComparativaFinal = "sugiere que la evaluación continua actúa como un refuerzo competencial que aún no se aprovecha totalmente, ya que el alumnado demuestra mejor nivel en el examen que en las actividades complementarias."
    Else
        diagComparativaFinal = "sugiere que la evaluación continua actúa como un complemento equilibrado, confirmando que el trabajo diario y las pruebas teóricas avanzan en total sintonía."
    End If

    Dim varGlobal As Double
    varGlobal = ultimaMediaGlobal - primeraMediaGlobal
    
    Dim diagTendenciaGlobal As String
    If varGlobal > 0.5 Then
        diagTendenciaGlobal = "una tendencia ascendente, lo que refleja una maduración positiva del grupo y una sólida adaptación a la metodología conforme avanzaba el temario."
    ElseIf varGlobal < -0.5 Then
        diagTendenciaGlobal = "una tendencia descendente, sugiriendo que la mayor complejidad de los temas finales o la fatiga acumulada han afectado al rendimiento de la cohorte."
    Else
        diagTendenciaGlobal = "una tendencia estable, demostrando un ritmo de trabajo muy lineal y una constancia notable en el rendimiento académico del alumnado."
    End If

    txtFinal = "|INFORME FINAL DE EVALUACIÓN|" & vbCrLf & vbCrLf
    txtFinal = txtFinal & "La asignatura |" & NombreAsignatura & "| ha contado durante el curso académico |" & CursoAcademico & "| con |" & totalMatriculados & " alumnos matriculados|: "
    txtFinal = txtFinal & "|" & numNP & " no presentados|, |" & numReconocimientos & " Reconocimientos de Créditos| y |" & numAprobadosPrevios & " Aprobados previos|." & vbCrLf & vbCrLf
    txtFinal = txtFinal & "La calificación media global ha sido de |" & Format(valMedia, "0.00") & "|, con una mediana de |" & Format(valMediana, "0.00") & "|, lo que indica que " & diagMediana & vbCrLf & vbCrLf
    txtFinal = txtFinal & "La desviación estándar se sitúa en |" & Format(valDesv, "0.00") & "|, con un coeficiente de variación del |" & Format(valCV, "0.0%") & "|, lo que indica un nivel de dispersión |" & nivelDispersion & "| en el rendimiento del alumnado." & vbCrLf & vbCrLf
    txtFinal = txtFinal & "El rango total de calificaciones abarca |" & Format(valRango, "0.0") & " puntos|, situándose el 50% central del alumnado en la franja comprendida entre el |" & Format(Q1, "0.0") & "| y el |" & Format(Q3, "0.0") & "|. Con un rango intercuartílico (IQR) de |" & Format(valIQR, "0.0") & " puntos|, observamos que " & diagIQR & vbCrLf & vbCrLf
    txtFinal = txtFinal & "El percentil 10 se sitúa en |" & Format(valP10, "0.00") & "| " & diagP10 & vbCrLf & vbCrLf
    txtFinal = txtFinal & "El percentil 90 se sitúa en |" & Format(valP90, "0.00") & "| " & diagP90 & vbCrLf & vbCrLf
    txtFinal = txtFinal & "El porcentaje global de aprobados ha sido del |" & Format(porcAprobados, "0%") & "| (|" & cantAprobados & "| alumnos), mientras que el |" & Format(porcSuspensos, "0%") & "| ha suspendido (|" & cantSuspensos & "| alumnos), obteniendo estos una media de |" & Format(mediaSuspensos, "0.00") & "|. " & diagExito & " " & diagSuspensos & vbCrLf & vbCrLf
    txtFinal = txtFinal & "La distribución presenta una asimetría de |" & Format(valAsimetria, "0.00") & "| y una curtosis de |" & Format(valCurtosis, "0.00") & "|. " & diagAsim & " Por su parte, " & diagKurt & " " & diagRecortada & vbCrLf & vbCrLf
    txtFinal = txtFinal & "En cuanto al análisis por bloques, la media del bloque de |Exámenes Parciales| ha sido de |" & Format(mediaBloqueEx, "0.00") & "|, con una desviación estándar de |" & Format(sdBloqueEx, "0.00") & "|. " & diagBloqueEx & " "
    txtFinal = txtFinal & "El índice de dificultad del bloque se sitúa en |" & Format(mediaDificultadEx, "0.00") & "|, " & txtDificultad & " "
    txtFinal = txtFinal & "Por su parte, el índice de discriminación es de |" & Format(mediaDiscriminacionEx, "0.00") & "|, " & txtDiscriminacion & " "
    txtFinal = txtFinal & "El porcentaje de aprobados en este bloque ha sido del |" & Format(porcAprobadosEx, "0%") & "|, " & txtAnalisisTendenciaEx & " con " & txtAnalisisVariacionEx & vbCrLf & vbCrLf
    If contAct > 0 Then
        txtFinal = txtFinal & "Por su parte, la media del bloque de |Actividades Complementarias| ha sido de |" & Format(mediaBloqueAct, "0.00") & "|, con una desviación estándar de |" & Format(sdBloqueAct, "0.00") & "| y un coeficiente de variación del |" & Format(cvBloqueAct, "0%") & "| " & diagDispersionAct & " "
        txtFinal = txtFinal & "La diferencia entre la media de actividades y la de exámenes es de |" & Format(difActEx, "0.00") & " puntos|, " & diagDifActEx & " "
        txtFinal = txtFinal & "La evolución de este bloque muestra una tendencia " & diagTendenciaAct & " con una variación acumulada de |" & Format(varMediaAct, "0.0") & " puntos| a lo largo del curso." & vbCrLf & vbCrLf
        txtFinal = txtFinal & "La comparación entre ambos bloques " & diagComparativaFinal & vbCrLf & vbCrLf
    End If

    txtFinal = txtFinal & "Desde una perspectiva evolutiva global, el rendimiento del grupo ha mostrado |" & diagTendenciaGlobal & "| con una variación media acumulada de |" & Format(varGlobal, "0.0") & " puntos| desde el inicio hasta el cierre del curso académico."

    On Error Resume Next
    ws.Shapes("InformeFinal_Texto").Delete
    On Error GoTo 0
    
    Set shp = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, rngPosicion.Left, rngPosicion.Top, rngPosicion.Width, rngPosicion.Height)
    With shp
        .Name = "InformeFinal_Texto"
        .Line.ForeColor.RGB = RGB(0, 0, 0)
        .Line.Weight = 2.5
        .Fill.Visible = msoTrue
        .Fill.ForeColor.RGB = RGB(255, 255, 255)
        .Fill.Transparency = 0
        With .TextFrame2
            .TextRange.Text = txtFinal
            .TextRange.Font.Size = 11
            .TextRange.Font.Name = "Calibri"
            .WordWrap = msoTrue
            
            Dim iStart As Long, iEnd As Long
            Do
                iStart = InStr(.TextRange.Text, "|")
                If iStart = 0 Then
                    Exit Do
                End If
                .TextRange.Characters(iStart, 1).Delete
                iEnd = InStr(iStart, .TextRange.Text, "|")
                If iEnd > 0 Then
                    .TextRange.Characters(iStart, iEnd - iStart).Font.bold = True
                    .TextRange.Characters(iEnd, 1).Delete
                End If
            Loop
        End With
    End With
    With ws.Range("AK2:AQ22")
        .Font.Color = RGB(255, 255, 255)
        .Borders.LineStyle = xlNone
    End With
    CrearBotonExportarFinal
End Sub

Sub CrearBotonExportarFinal()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim rngboton As Range: Set rngboton = ws.Range("K1:N2")
    Dim btn As Button
    
    On Error Resume Next
    ws.Buttons("btnExportarPDF").Delete
    On Error GoTo 0
    
    Set btn = ws.Buttons.Add(rngboton.Left, rngboton.Top, rngboton.Width, rngboton.Height)
    
    With btn
        .Name = "btnExportarPDF"
        .Caption = "EXPORTAR INFORME A PDF"
        .OnAction = "ExportarInformePDF_Final"
        .Font.Name = "Calibri"
        .Font.bold = True
        .Font.Size = 11
    End With
    VolverAlInicio
    Application.ScreenUpdating = True
End Sub

Sub ExportarInformePDF_Final()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim rutaCarpeta As String, nombreArchivo As String
    
    If ThisWorkbook.Path = "" Then
        MsgBox "Por favor, guarde primero su archivo de Excel en una carpeta.", vbCritical, "Error de Ruta"
        Exit Sub
    End If

    rutaCarpeta = ThisWorkbook.Path & "\"
    nombreArchivo = ws.Name & ".pdf"
    
    Application.ScreenUpdating = False
    
    ws.ResetAllPageBreaks
    
    With ws.PageSetup
        .PrintArea = "$D$2:$M$82,$O$2:$X$72"
        .Orientation = xlPortrait
        .PaperSize = xlPaperA4
        .Zoom = False
        .FitToPagesWide = 1
        .FitToPagesTall = 1
        .CenterHorizontally = True
        .CenterVertically = False
        .TopMargin = Application.CentimetersToPoints(1)
        .BottomMargin = Application.CentimetersToPoints(1)
    End With
    
    On Error Resume Next
    ws.ExportAsFixedFormat _
        Type:=xlTypePDF, _
        Filename:=rutaCarpeta & nombreArchivo, _
        OpenAfterPublish:=True, _
        IgnorePrintAreas:=False
        
    If Err.Number <> 0 Then
        MsgBox "Error: El PDF no se pudo generar. Verifique si ya está abierto.", vbCritical
    Else
        MsgBox "Generado:" & vbCrLf & nombreArchivo, vbInformation
    End If
    On Error GoTo 0
    VolverAlInicio
    Application.ScreenUpdating = True
End Sub


