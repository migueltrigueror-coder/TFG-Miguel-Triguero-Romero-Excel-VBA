        .HasTitle = True
        .ChartTitle.Text = "Distribución de Notas"
        With .ChartTitle.Format.TextFrame2.TextRange.Font
            .bold = msoTrue
            .Size = 18
            .Fill.ForeColor.RGB = RGB(0, 0, 0)
        End With
        Do While .SeriesCollection.count > 0: .SeriesCollection(1).Delete: Loop
        
        With .Axes(xlValue)
            .MinimumScale = 0: .MaximumScale = 10: .MajorUnit = 1
            .TickLabels.Font.bold = msoTrue
            .Format.Line.ForeColor.RGB = RGB(0, 0, 0)
        End With
        .Axes(xlCategory).Delete

        With .SeriesCollection.NewSeries
            .Values = Array(Q1)
            .Format.Fill.Visible = msoFalse
            .HasErrorBars = True
            .ErrorBar Direction:=xlX, Include:=xlMinusValues, Type:=xlCustom, Amount:=0, MinusValues:=Array(Q1 - minVal)
            .ErrorBars.Format.Line.Weight = 2.25: .ErrorBars.Format.Line.ForeColor.RGB = RGB(0, 0, 0)
        End With
        
        With .SeriesCollection.NewSeries
            .Values = Array(q2 - Q1)
            .Format.Fill.ForeColor.RGB = RGB(180, 210, 245)
            With .Format.Line: .Visible = msoTrue: .ForeColor.RGB = RGB(0, 0, 0): .Weight = 2.25: End With
        End With
        
