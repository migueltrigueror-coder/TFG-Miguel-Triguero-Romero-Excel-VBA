Sub GenerarInformeTextoAlumno()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim shp As Shape
    Dim txtInforme As String
    Dim nombreHoja As String, nombreAlumno As String
    Dim i As Integer, j As Integer
    Dim totalPruebasRealizadas As Integer
    Dim pruebasConZScore As Integer
    Dim nota As Variant, zScore As Double
    Dim mediaClaseIndiv As Variant, desvEstClase As Variant
    Dim desempeño As String, rendimientoTxt As String
    Dim pesoEvaluado As Double, valI14 As Variant
    Dim notasAlumno() As Double
    Dim rngInforme As Range

    nombreHoja = ws.Name
    Dim partes() As String: partes = Split(nombreHoja, " ")
    If UBound(partes) > 0 Then
        For j = 1 To UBound(partes): nombreAlumno = nombreAlumno & partes(j) & " ": Next j
        nombreAlumno = Trim(nombreAlumno)
    Else: nombreAlumno = nombreHoja: End If

    On Error Resume Next: ws.Shapes("ContenedorInformeAlumno").Delete: On Error GoTo 0

    totalPruebasRealizadas = 0
    For i = 1 To 5
        If IsNumeric(ws.Cells(4, i).Value) And Not IsEmpty(ws.Cells(4, i)) Then
            totalPruebasRealizadas = totalPruebasRealizadas + 1
        End If
    Next i

    Dim titulo As String: titulo = "|INFORME PERSONALIZADO DE EVALUACIÓN|"
    txtInforme = titulo & vbCrLf & vbCrLf
    txtInforme = txtInforme & "El alumno " & nombreAlumno & " ha realizado hasta ahora |" & totalPruebasRealizadas & " pruebas|, con las siguientes calificaciones:" & vbCrLf & vbCrLf

    pruebasConZScore = 0: pesoEvaluado = 0
    For i = 1 To 5
        If IsNumeric(ws.Cells(4, i).Value) And Not IsEmpty(ws.Cells(4, i)) Then
            nota = ws.Cells(4, i).Value
            mediaClaseIndiv = ws.Cells(1, i + 26).Value
            desvEstClase = ws.Cells(2, i + 26).Value
            pesoEvaluado = pesoEvaluado + ws.Cells(2, i).Value
            
            If IsNumeric(mediaClaseIndiv) And IsNumeric(desvEstClase) Then
                If desvEstClase > 0 Then
                    pruebasConZScore = pruebasConZScore + 1
                    ReDim Preserve notasAlumno(1 To pruebasConZScore): notasAlumno(pruebasConZScore) = nota
                    zScore = (nota - CDbl(mediaClaseIndiv)) / CDbl(desvEstClase)
                    
                    Select Case zScore
                        Case Is > 1.2: desempeño = "|muy por encima de la media|"
                        Case 0.5 To 1.2: desempeño = "|por encima de la media|"
                        Case -0.5 To 0.49: desempeño = "|en la media|"
                        Case -1.2 To -0.51: desempeño = "|por debajo de la media|"
                        Case Is < -1.2: desempeño = "|muy por debajo de la media|"
                    End Select
                    
                    txtInforme = txtInforme & "     • " & ws.Cells(3, i).Value & " – Nota: |" & Format(nota, "0.00") & "| con un Z-Score de |" & Format(zScore, "0.0") & "|. Su desempeño fue " & desempeño & "." & vbCrLf
                End If
            End If
        End If
    Next i

    If pruebasConZScore >= 2 Then
        Dim rngEstad As Range: Set rngEstad = ws.Range("A4:E4")
        Dim dsEt As Double: dsEt = Application.WorksheetFunction.StDev_P(rngEstad)
        Dim nMax As Double: nMax = Application.WorksheetFunction.Max(rngEstad)
        Dim nMin As Double: nMin = Application.WorksheetFunction.Min(rngEstad)
        
        Dim esteb As String
        Select Case dsEt
            Case Is < 0.5: esteb = "|muy estables|"
            Case 0.5 To 1.2: esteb = "|bastante estables|"
            Case Is > 1.2: esteb = "|poco estables|"
        End Select
        
        txtInforme = txtInforme & vbCrLf & "Como vemos, dado que su desviación típica es de |" & Format(dsEt, "0.00") & _
                     "| y su rango de notas oscila entre |" & Format(nMax, "0.00") & " (máx)| y |" & Format(nMin, "0.00") & _
                     " (mín)|, sus calificaciones por ahora son " & esteb & "." & vbCrLf & vbCrLf
    End If

    Dim mPondA: mPondA = ws.Range("F4").Value
    Dim mPondC: mPondC = ws.Range("AF1").Value
    Dim dif As Double: dif = mPondA - mPondC
    Dim comp: Select Case dif
        Case Is > 1.5: comp = "|muy por encima de la media|"
        Case 0.2 To 1.5: comp = "|por encima de la media|"
        Case -0.2 To 0.19: comp = "|en la media|"
        Case -1.5 To -0.21: comp = "|por debajo de la media|"
        Case Is < -1.5: comp = "|muy por debajo de la media|"
    End Select
    txtInforme = txtInforme & "Su nota media ponderada actual es de |" & Format(mPondA, "0.00") & "| que se encuentra " & comp & " de su clase." & vbCrLf & vbCrLf

