    ElseIf ws.Range("G14").Value < 0 Then
        txtInforme = txtInforme & "Con las calificaciones actuales, el alumno sigue el perfil de |Alumno que ha Empeorado en los Exámenes Desde el Inicio de la Asignatura|."
    ElseIf ws.Range("E14").Value - ws.Range("F14").Value > 1.5 Then
        txtInforme = txtInforme & "Con las calificaciones actuales, el alumno sigue el perfil de |Rendimiento Excepcional en Examen Final|."
    ElseIf ws.Range("E14").Value - ws.Range("F14").Value < -1.5 Then
