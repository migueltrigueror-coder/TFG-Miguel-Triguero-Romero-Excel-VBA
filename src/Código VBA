Sub BotonInformeExamen()
    Dim wsDatos As Worksheet
    Dim colBoton As Long
    Dim objBoton As Object
    
    Set wsDatos = ActiveSheet

    On Error Resume Next
    Set objBoton = wsDatos.Shapes(Application.Caller)
    On Error GoTo 0
    
    If Not objBoton Is Nothing Then
        colBoton = objBoton.TopLeftCell.Column
        
        CopiarDatosExamenConAlumnos wsDatos, colBoton
        CopiarEstadistica wsDatos, colBoton
    Else
        MsgBox "Por favor, asigna esta macro a un botón de formulario.", vbCritical
    End If
End Sub

Sub CopiarDatosExamenConAlumnos(wsOrigen As Worksheet, colExamen As Long)
    Dim wsNueva As Worksheet
    Dim nombreExamen As String
    Dim colAlumnos As Long: colAlumnos = 3
    Dim filaDestino As Long
    Dim ws As Worksheet
    Dim nombreLimpio As String
    Application.ScreenUpdating = False
    nombreExamen = "Informe " & wsOrigen.Cells(3, colExamen).Value
    
    nombreLimpio = nombreExamen
    Dim charArr As Variant, c As Variant
    charArr = Array("/", "\", "[", "]", "*", "?", ":")
    For Each c In charArr: nombreLimpio = Replace(nombreLimpio, c, ""): Next c
    
    Application.DisplayAlerts = False
    On Error Resume Next
    For Each ws In ThisWorkbook.Sheets

        If ws.Name = nombreLimpio Or (ws.Range("Z1").Value = colExamen And ws.Name <> wsOrigen.Name) Then
            ws.Delete
        End If
    Next ws
    On Error GoTo 0
    Application.DisplayAlerts = True

    Set wsNueva = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.count))
    wsNueva.Name = nombreLimpio
    
    With wsNueva.Range("A1:E1")
        .Merge
        .Value = wsNueva.Name
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .Font.bold = True
        .Font.Size = 13
        .Interior.Color = RGB(255, 230, 153)
        .BorderAround LineStyle:=xlContinuous, Weight:=xlMedium
    End With
    With wsNueva.Range("G4:Y40")
        .Merge
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .Font.bold = True
        .Font.Size = 13
        .Interior.Color = RGB(255, 255, 255)
        .BorderAround LineStyle:=xlContinuous, Weight:=xlThick
    End With
    With wsNueva.Range("AA4:AG40")
        .Merge
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .Font.bold = True
        .Font.Size = 13
        .Interior.Color = RGB(255, 255, 255)
        .BorderAround LineStyle:=xlContinuous, Weight:=xlThick
    End With
    Set ws = ActiveSheet
    
    Set rng = ws.Range("H5:X6")
    
    Set shp = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, _
                                  rng.Left, _
                                  rng.Top, _
                                  rng.Width, _
                                  rng.Height)
                                  
    With shp
        .Name = "GRÁFICOS ESTADÍSTICOS"
        
        .Fill.ForeColor.RGB = RGB(169, 208, 142)
        .Line.ForeColor.RGB = RGB(0, 0, 0)
        .Line.Weight = 2
        
        With .TextFrame2
            .VerticalAnchor = msoAnchorMiddle
            .TextRange.ParagraphFormat.Alignment = msoAlignCenter
            With .TextRange
            .Text = "GRÁFICOS ESTADÍSTICOS"
            .Font.Size = 14
            .Font.Name = "Arial"
            .Font.bold = msoTrue '
            .Font.Fill.ForeColor.RGB = RGB(0, 0, 0)
            End With
        End With
    End With
    Set ws = ActiveSheet
    
    Set rng = ws.Range("AB5:AF6")
    
    Set shp = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, _
                                  rng.Left, _
                                  rng.Top, _
                                  rng.Width, _
                                  rng.Height)
                                  
    With shp
        .Name = "Análisis " & wsOrigen.Cells(3, colExamen).Value
        
        .Fill.ForeColor.RGB = RGB(169, 208, 142)
        .Line.ForeColor.RGB = RGB(0, 0, 0)
        .Line.Weight = 2
        
        With .TextFrame2
            .VerticalAnchor = msoAnchorMiddle
            .TextRange.ParagraphFormat.Alignment = msoAlignCenter
            With .TextRange
            .Text = "Análisis" & " " & wsOrigen.Cells(3, colExamen).Value
            .Font.Size = 14
            .Font.Name = "Arial"
            .Font.bold = msoTrue
            .Font.Fill.ForeColor.RGB = RGB(0, 0, 0)
            End With
        End With
    End With
    wsNueva.Rows(1).RowHeight = 28
    wsOrigen.Range(wsOrigen.Cells(2, colExamen), wsOrigen.Cells(4, colExamen)).Copy Destination:=wsNueva.Range("B3")

    filaDestino = 6
    Dim rangos As Variant, r As Variant
    rangos = Array("5:88", "90:127")
    
    For Each r In rangos
        Dim fIni As Long: fIni = Split(r, ":")(0)
        Dim fFin As Long: fFin = Split(r, ":")(1)
        For i = fIni To fFin
            If wsOrigen.Cells(i, colAlumnos).Value <> "" Then
                wsOrigen.Cells(i, colAlumnos).Copy Destination:=wsNueva.Cells(filaDestino, 1)
                wsOrigen.Cells(i, colExamen).Copy Destination:=wsNueva.Cells(filaDestino, 2)
                filaDestino = filaDestino + 1
            End If
        Next i
    Next r
    
    wsNueva.Range("Z1").Value = colExamen
    wsNueva.Range("Z1").Font.Color = vbWhite
    wsNueva.Columns("A:E").AutoFit
    GenerarGraficosInforme
    CrearBotonExportar
    wsNueva.Columns("A:B").Hidden = True
    Set rng = wsNueva.Range("N1:Q2")
    Set btnVer = wsNueva.Buttons.Add(rng.Left, rng.Top, rng.Width, rng.Height)
    
    With btnVer
        .Name = "BtnVerDatos"
        .Caption = "MOSTRAR LISTADO ALUMNOS Y CALIFICACIONES"
        .OnAction = "AlternarVisibilidadDatos"
        With .Font
            .bold = True
            .Name = "Calibri"
            .Size = 11
        End With
    End With
    
    Set rng = wsNueva.Range("R1:U2")
    Set btnInformTXT = wsNueva.Buttons.Add(rng.Left, rng.Top, rng.Width, rng.Height)
    
    With btnInformTXT
        .Name = "btnInformTXT"
        .Caption = "GENERAR INFORME DE TEXTO"
        .OnAction = "GenerarTextoEvaluacionExamen"
        With .Font
            .bold = True
            .Name = "Calibri"
            .Size = 11
        End With
    End With
    Dim cho As ChartObject
    For Each cho In wsNueva.ChartObjects
        cho.Chart.PlotVisibleOnly = False
    Next cho
    Dim guia As Shape
    Dim txtGuia As String
    
    txtGuia = "GUÍA RÁPIDA DE ESTADÍSTICA:" & vbCrLf & vbCrLf & _
              "• MEDIA: Promedio de notas del grupo." & vbCrLf & vbCrLf & _
              "• MEDIANA: El valor central; 50% del grupo está por encima/debajo." & vbCrLf & vbCrLf & _
              "• DESVIACIÓN ESTÁNDAR: Indica qué tan dispersas están las notas. Un valor alto significa notas muy variadas; uno bajo, notas similares." & vbCrLf & vbCrLf & _
              "• COEFICIENTE DE VARIACIÓN: Medida de dispersión relativa que relaciona la desviación estándar con la media de las calificaciones." & vbCrLf & vbCrLf & _
              "• RANGO: Diferencia entre la nota más alta y la más baja." & vbCrLf & vbCrLf & _
              "• RANGO INTERCUARTÍLICO: Indica la dispersión de la mitad central de la clase." & vbCrLf & vbCrLf & _
              "• ASIMETRÍA: Indica si la distribución está sesgada. > 0: mayoría notas bajas; < 0: mayoría notas altas." & vbCrLf & vbCrLf & _
              "• CURTOSIS: Evalúa la concentración de notas cerca de la media o presencia de extremos:" & vbCrLf & vbCrLf & _
              "    - Alta (Leptocúrtica): Pico pronunciado y colas pesadas. Indica más valores extremos (alumnos muy altos/bajos)." & vbCrLf & vbCrLf & _
              "    - Baja (Platicúrtica): Distribución aplanada, menos valores extremos y más dispersión general." & vbCrLf & vbCrLf & _
              "    - Cercana a 0 (Mesocúrtica): Distribución similar a la normal." & vbCrLf & vbCrLf & _
              "• 1º CUARTIL (Q1): Valor que deja por debajo al 25% de los alumnos." & vbCrLf & vbCrLf & _
              "• 3º CUARTIL (Q3): Valor que deja por debajo al 75% de los alumnos." & vbCrLf & vbCrLf & _
              "• PERCENTIL 90%: Nota por encima de la cual solo se encuentra el 10% de la clase." & vbCrLf & vbCrLf & _
              "• ALUMNOS TOP 10%: Identificación del grupo con rendimiento de excelencia." & vbCrLf & vbCrLf & _
              "• OUTLIERS: Valores atípicos (notas inusualmente altas o bajas) que se alejan del promedio." & vbCrLf & vbCrLf & _
              "• Nº APROBADOS: Cantidad total de alumnos con calificación >= 5." & vbCrLf & vbCrLf & _
              "• PORCENTAJE APROBADOS: Proporción de éxito sobre el total de alumnos presentados." & vbCrLf & vbCrLf & _
              "• GRAVEDAD SUSPENSOS: Análisis de qué tan lejos se quedaron los suspensos del aprobado (5)." & vbCrLf & vbCrLf & _
              "• INTERVALO DE CONFIANZA: Rango en el que se estima que se encuentra la media real del grupo." & vbCrLf & vbCrLf & _
              "• MEDIA RECORTADA: Promedio calculado eliminando los extremos para evitar distorsiones." & vbCrLf & vbCrLf & _
              "• ÍNDICE DE DISCRIMINACIÓN: Capacidad del examen para diferenciar alumnos con altos y bajos conocimientos." & vbCrLf & vbCrLf & _
              "• ÍNDICE DE DIFICULTAD: : Evalúa la complejidad intrínseca de la prueba. Es la proporción de la nota media alcanzada respecto al máximo posible."


    Set guia = wsNueva.Shapes.AddTextbox(msoTextOrientationHorizontal, _
               wsNueva.Range("H4").Left, wsNueva.Range("H4").Top, 850, 800)
               
    With guia
        .Name = "CuadroGuia"
        .Fill.ForeColor.RGB = RGB(255, 255, 235)
        .Line.ForeColor.RGB = RGB(0, 0, 0)
        .Line.Weight = 3
        .Visible = msoFalse
        
        With .TextFrame2.TextRange
            .Text = txtGuia
            .Font.Size = 14
            .Font.Name = "Calibri"
            .Font.Fill.ForeColor.RGB = RGB(0, 0, 0)
            .Characters(1, 26).Font.bold = msoTrue
            .Characters(1, 26).Font.UnderlineStyle = msoUnderlineSingleLine
        End With
    End With

    Dim btnAyuda As Button
    Set btnAyuda = wsNueva.Buttons.Add(wsNueva.Range("D3:E3").Left, _
                                      wsNueva.Range("D3:E3").Top, _
                                      wsNueva.Range("D3:E3").Width, _
                                      wsNueva.Range("D3:E3").Height)
    
    With btnAyuda
        .Name = "BtnAyudaEst"
        .Caption = "GUÍA ESTADÍSTICA"
        .OnAction = "AlternarGuiaEstadistica"
        With .Font
            .bold = True
            .Size = 10
        End With
    End With
    MsgBox "Generado " & wsNueva.Name, vbInformation
End Sub
Sub AlternarVisibilidadDatos()
    Dim ws As Worksheet
    Set ws = ActiveSheet
    
    If ws.Columns("A:B").Hidden = True Then
        ws.Columns("A:B").Hidden = False
        ws.Buttons("BtnVerDatos").Caption = "OCULTAR LISTADO ALUMNOS Y CALIFICACIONES"
    Else
        ws.Columns("A:B").Hidden = True
        ws.Buttons("BtnVerDatos").Caption = "MOSTRAR LISTADO ALUMNOS Y CALIFICACIONES"
    End If
End Sub

Sub AlternarGuiaEstadistica()
    Dim shp As Shape
    On Error Resume Next
    Set shp = ActiveSheet.Shapes("CuadroGuia")
    On Error GoTo 0
    
    If Not shp Is Nothing Then
        shp.Visible = IIf(shp.Visible = msoTrue, msoFalse, msoTrue)
    Else
        MsgBox "No se encontró el cuadro de guía en esta hoja.", vbExclamation
    End If
End Sub
Sub CopiarEstadistica(wsOrigen As Worksheet, colExamen As Long)
    Dim wsNueva As Worksheet
    Dim rngNombres As Range, rngValores As Range
    Dim filaInicio As Long: filaInicio = 4
    Dim ultimaFilaStats As Long
    
    Set wsNueva = ThisWorkbook.Sheets(ThisWorkbook.Sheets.count)
    Set rngNombres = wsOrigen.Range("C128:C148")
    Set rngValores = wsOrigen.Range(wsOrigen.Cells(128, colExamen), wsOrigen.Cells(148, colExamen))
    
    rngNombres.Copy
    wsNueva.Range("D" & filaInicio).PasteSpecial Paste:=xlPasteValuesAndNumberFormats
    
    rngValores.Copy
    wsNueva.Range("E" & filaInicio).PasteSpecial Paste:=xlPasteValuesAndNumberFormats
    
    ultimaFilaStats = wsNueva.Cells(wsNueva.Rows.count, "D").End(xlUp).Row
    
    With wsNueva.Range("D" & filaInicio & ":D" & ultimaFilaStats)
        .Interior.Color = RGB(220, 234, 247)
        .Font.Color = vbBlack
        .Font.bold = True
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .Borders.LineStyle = xlContinuous
    End With
    
    With wsNueva.Range("E" & filaInicio & ":E" & ultimaFilaStats)
        .HorizontalAlignment = xlCenter
        .VerticalAlignment = xlCenter
        .Borders.LineStyle = xlContinuous
    End With
    
    wsNueva.Range("D" & filaInicio & ":E" & ultimaFilaStats).BorderAround _
        LineStyle:=xlContinuous, Weight:=xlThick

    Application.CutCopyMode = False
    wsNueva.Columns("D:E").AutoFit
    wsNueva.Activate
    
    Dim btn As Button
    Dim rngboton As Range
    
    Set rngboton = wsNueva.Range("F1:I2")
    

    Set btn = wsNueva.Buttons.Add(rngboton.Left, rngboton.Top, rngboton.Width, rngboton.Height)
    
    With btn
        .Caption = "ELIMINAR INFORME Y VOLVER"
        .OnAction = "EliminarHojaActual"
        .Font.bold = True

    End With
End Sub

Sub EliminarHojaActual()
    Dim nombreHoja As String
    nombreHoja = ActiveSheet.Name

    If nombreHoja = "Notas" Then
        MsgBox "No puedes eliminar la hoja principal.", vbCritical
        Exit Sub
    End If

    If MsgBox("¿Estás seguro de que quieres borrar este informe?", vbQuestion + vbYesNo, "Confirmar") = vbYes Then
        Application.DisplayAlerts = False
        ActiveSheet.Delete
        Application.DisplayAlerts = True
  
        On Error Resume Next
        Sheets("Notas").Activate
        On Error GoTo 0
    End If
End Sub

Sub GenerarGraficosInforme()
    Dim ws As Worksheet
    Dim lastRow As Long, numAlumnos As Long, n27 As Long
    Dim i As Integer
    Dim media As Double, desvTip As Double, Mediana As Double, vAsimetria As Double, vCurtosis As Double
    Dim mediaTop27 As Double, mediaBottom27 As Double, discIndice As Double
    Dim indiceDificultad As Double, coefVar As Double, p73 As Double, p27 As Double
    Dim chartObj As ChartObject, srs As Series
    Dim shpStats As Shape
    Dim txtStats As String, ajustePoisson As String
    Dim celda As Range
    Dim sumaTop As Double, sumaBottom As Double
    Dim contTop As Long, contBottom As Long
    
    Set ws = ActiveSheet
    lastRow = ws.Cells(ws.Rows.count, "B").End(xlUp).Row
    numAlumnos = lastRow - 5

    If lastRow < 6 Then
        MsgBox "No hay datos suficientes en la columna B.", vbExclamation
        Exit Sub
    End If

    media = Application.WorksheetFunction.Average(ws.Range("B6:B" & lastRow))
    desvTip = Application.WorksheetFunction.StDev_S(ws.Range("B6:B" & lastRow))
    Mediana = Application.WorksheetFunction.Median(ws.Range("B6:B" & lastRow))
    indiceDificultad = media / 10
    coefVar = desvTip / media
    vAsimetria = Application.WorksheetFunction.Skew(ws.Range("B6:B" & lastRow))
    vCurtosis = Application.WorksheetFunction.Kurt(ws.Range("B6:B" & lastRow))
    n27 = Application.WorksheetFunction.Round(numAlumnos * 0.27, 0)
    If n27 = 0 Then n27 = 1

    p73 = Application.WorksheetFunction.Percentile_Exc(ws.Range("B6:B" & lastRow), 0.73)
    p27 = Application.WorksheetFunction.Percentile_Exc(ws.Range("B6:B" & lastRow), 0.27)
    
    For Each celda In ws.Range("B6:B" & lastRow)
        If IsNumeric(celda.Value) And Not IsEmpty(celda) Then
            If celda.Value > p73 Then
                sumaTop = sumaTop + celda.Value
                contTop = contTop + 1
            End If
            If celda.Value < p27 Then
                sumaBottom = sumaBottom + celda.Value
                contBottom = contBottom + 1
            End If
        End If
    Next celda
    If contTop > 0 Then mediaTop27 = sumaTop / contTop Else mediaTop = 0
    If contBottom > 0 Then mediaBottom27 = sumaBottom / contBottom Else mediaBottom = 0
    discIndice = (mediaTop27 - mediaBottom27) / 10
    Dim sigmaRef As Double: sigmaRef = 2.4
    Dim totalN As Long: totalN = 101
    Dim pi As Double: pi = 3.14159265
    Dim constanteGauss As Double
    
    constanteGauss = totalN / (sigmaRef * Sqr(2 * pi))
    
    ws.Range("AC100:AC109").ClearContents
    
    For i = 0 To 9
        Dim x As Double: x = i + 0.5
        ws.Cells(100 + i, "AC").Value = constanteGauss * Exp(-0.5 * ((x - 5) / sigmaRef) ^ 2)
    Next i
    ws.Range("Z100:AB200").ClearContents
    
    For i = 0 To 9
        ws.Cells(100 + i, "Z").Value = "'" & i & "-" & (i + 1)

        If i = 9 Then
            ws.Cells(100 + i, "AA").Value = Application.WorksheetFunction.CountIfs( _
                ws.Range("B6:B" & lastRow), ">=9", _
                ws.Range("B6:B" & lastRow), "<=10")
        Else
            ws.Cells(100 + i, "AA").Value = Application.WorksheetFunction.CountIfs( _
                ws.Range("B6:B" & lastRow), ">=" & i, _
                ws.Range("B6:B" & lastRow), "<" & (i + 1))
        End If
    Next i

    ws.Range("AB100:AB109").Formula = "=SUM(AA$100:AA100)/SUM(AA$100:AA$109)"

    ws.Range("Z120").Value = "Aprobados": ws.Range("AA120").Value = Application.CountIf(ws.Range("B6:B" & lastRow), ">=5")
    ws.Range("Z121").Value = "Suspensos": ws.Range("AA121").Value = Application.CountIf(ws.Range("B6:B" & lastRow), "<5")
    ws.Range("Z122").Value = "Media":     ws.Range("AA122").Value = media

    On Error Resume Next: ws.ChartObjects.Delete: On Error GoTo 0

    Set chartObj = ws.ChartObjects.Add(ws.Range("Q9").Left, ws.Range("Q9").Top, 360, 250)
    EstiloBase chartObj, "Histograma de Calificaciones"
    
    With chartObj.Chart

        Do While .SeriesCollection.count > 0: .SeriesCollection(1).Delete: Loop
        
        Set srs = .SeriesCollection.NewSeries
        With srs
            .Name = "Distribución Notas"
            .Values = ws.Range("AA100:AA109")
            .XValues = ws.Range("Z100:Z109")
            .ChartType = xlColumnClustered
            .HasDataLabels = True
            
            Dim p As Integer
            For p = 1 To 10
                With .Points(p).Format.Fill
                    Select Case p
                        Case 1 To 3: .ForeColor.RGB = RGB(255, 180, 180)
                        Case 4 To 5: .ForeColor.RGB = RGB(255, 192, 0)
                        Case 6 To 7: .ForeColor.RGB = RGB(169, 208, 142)
                        Case Else:   .ForeColor.RGB = RGB(155, 194, 230)
                    End Select
                End With
            Next p
        End With
        
        With .SeriesCollection.NewSeries
            .Name = "% Acumulado"
            .Values = ws.Range("AB100:AB109")
            .XValues = ws.Range("Z100:Z109")
            .ChartType = xlLine
            .AxisGroup = xlSecondary
            .Format.Line.ForeColor.RGB = RGB(255, 102, 0)
            .Format.Line.Weight = 1.5
            .MarkerStyle = xlMarkerStyleSquare
            .MarkerSize = 2
            .MarkerBackgroundColor = RGB(255, 102, 0)
        End With
        

    With .SeriesCollection.NewSeries
            .Name = "Curva Normal (Gauss)"
            .Values = ws.Range("AC100:AC109")
            .XValues = ws.Range("Z100:Z109")
            .ChartType = xlLine
            .AxisGroup = xlPrimary
            
            With .Format.Line
                .Visible = msoTrue
                .ForeColor.RGB = RGB(0, 0, 0)
                .Weight = 2.5
            End With
            
            .MarkerStyle = xlMarkerStyleNone
            On Error Resume Next
            .Smooth = True
            On Error GoTo 0
    End With

        .ChartGroups(1).GapWidth = 10
        .Axes(xlValue, xlSecondary).MaximumScale = 1
        .Axes(xlValue, xlSecondary).TickLabels.NumberFormat = "0%"
        .HasLegend = True
        .legend.Position = xlLegendPositionBottom
    End With

    Set chartObj = ws.ChartObjects.Add(ws.Range("Q25").Left, ws.Range("Q25").Top, 480, 250)
    EstiloBase chartObj, "Calidad del Examen"
    With chartObj.Chart
        .ChartType = xlBarClustered
        Set srs = .SeriesCollection.NewSeries
        With srs
            .Values = Array(indiceDificultad, discIndice, coefVar)
            .XValues = Array("Índice Dificultad", "Índice Discriminación", "Coef. Variación")
            .HasDataLabels = True
            .DataLabels.NumberFormat = "0,00"
            With .Points(1).Format
                .Fill.ForeColor.RGB = RGB(155, 194, 230)
                .Line.ForeColor.RGB = RGB(47, 117, 181)
                .Line.Weight = 1
            End With
            With .Points(2).Format
                If discIndice < 0.2 Then
                    .Fill.ForeColor.RGB = RGB(247, 87, 83)
                    .Line.ForeColor.RGB = RGB(0, 0, 0)
                    .Line.Weight = 1
                Else
                    .Fill.ForeColor.RGB = RGB(255, 192, 0)
                    .Line.ForeColor.RGB = RGB(191, 144, 0)
                    .Line.Weight = 1
                End If
            End With
            With .Points(3).Format
                .Fill.ForeColor.RGB = RGB(169, 208, 142)
                .Line.ForeColor.RGB = RGB(84, 130, 53)
                .Line.Weight = 1
            End With
        End With
    End With
    If Abs(media - Mediana) < 0.5 And Abs(vAsimetria) < 0.5 Then
        ajustePoisson = "Ajuste a la Normal: ALTO. La clase se comporta de forma estándar (Campana de Gauss)."
    Else
        ajustePoisson = "Ajuste a la Normal: BAJO. La distribución es asimétrica; el examen fue muy fácil o muy difícil."
    End If
    txtStats = "Análisis Distribución:" & vbCrLf & _
               vbCrLf & _
               "Desv. Típica: " & Format(desvTip, "0.00") & vbCrLf & _
               "Coef. Asimetría: " & Format(vAsimetria, "0.000") & vbCrLf & _
               "Curtosis: " & Format(vCurtosis, "0.000") & vbCrLf & _
               vbCrLf & _
               ajustePoisson

    Set shpStats = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, _
                                        ws.Range("W9").Left, _
                                        ws.Range("W9").Top, _
                                        120, 250)
    
    With shpStats
        .Name = "CuadroResumenEstadistico"
        
        .Line.Visible = msoTrue
        .Line.ForeColor.RGB = RGB(0, 0, 0)
        .Line.Weight = 3
        
        .Fill.ForeColor.RGB = RGB(255, 255, 255)
        .Fill.Transparency = 0
        
        With .TextFrame2
            .MarginLeft = 7
            .MarginRight = 7
            .MarginTop = 7
            .VerticalAnchor = msoAnchorTop
            .WordWrap = msoTrue
            
            With .TextRange
                .Text = txtStats
                .Font.Name = "Arial"
                .Font.Size = 10
                .Font.Fill.ForeColor.RGB = RGB(0, 0, 0)
                
                With .Paragraphs(1)
                    .Font.bold = msoTrue
                    .Font.Size = 11
                End With
            End With
        End With
    End With
    GenerarGraficoDesdeCeldas
