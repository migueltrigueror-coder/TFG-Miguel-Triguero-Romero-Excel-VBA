Sub CopiarDatosFinales(wsOrigen As Worksheet, colExamen As Long)
    Dim wsNueva As Worksheet
    Dim nombreExamen As String
    Dim colAlumnos As Long: colAlumnos = 3
    Dim filaDestino As Long
    Dim ws As Worksheet
    Dim nombreLimpio As String
    Dim shp As Shape, rng As Range, btnVer As Button
    Dim i As Long
    Application.ScreenUpdating = False
    nombreExamen = "Informe Final Asignatura"
    nombreLimpio = nombreExamen
    Dim charArr As Variant, c As Variant
    charArr = Array("/", "\", "[", "]", "*", "?", ":")
    For Each c In charArr: nombreLimpio = Replace(nombreLimpio, c, ""): Next c
    
    Application.DisplayAlerts = False
    On Error Resume Next
    For Each ws In ThisWorkbook.Sheets
        If ws.Name = nombreLimpio Or (ws.Range("Z1").Value = colExamen And ws.Name <> wsOrigen.Name) Then
            ws.Delete
        End If
    Next ws
    On Error GoTo 0
    Application.DisplayAlerts = True

    Set wsNueva = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.count))
    wsNueva.Name = nombreLimpio

    wsNueva.Rows(1).RowHeight = 28
    wsOrigen.Range(wsOrigen.Cells(2, colExamen), wsOrigen.Cells(4, colExamen)).Copy
    With wsNueva.Range("B3")
        .PasteSpecial Paste:=xlPasteFormats
        .PasteSpecial Paste:=xlPasteValues
    End With

    filaDestino = 6
    Dim rangos As Variant, r As Variant
    rangos = Array("5:88", "90:127")
    
    For Each r In rangos
        Dim fIni As Long: fIni = Split(r, ":")(0)
        Dim fFin As Long: fFin = Split(r, ":")(1)
        For i = fIni To fFin
            If wsOrigen.Cells(i, colAlumnos).Value <> "" Then
                wsOrigen.Cells(i, colAlumnos).Copy
                wsNueva.Cells(filaDestino, 1).PasteSpecial Paste:=xlPasteFormats
                wsNueva.Cells(filaDestino, 1).PasteSpecial Paste:=xlPasteValues
                
                wsOrigen.Cells(i, colExamen).Copy
                wsNueva.Cells(filaDestino, 2).PasteSpecial Paste:=xlPasteFormats
                wsNueva.Cells(filaDestino, 2).PasteSpecial Paste:=xlPasteValues
                
                filaDestino = filaDestino + 1
            End If
        Next i
    Next r
    Application.CutCopyMode = False

    Dim totalAlumnos As Long: totalAlumnos = 0
    Dim nombreCompleto As String
    Dim ultimaFilaNueva As Long
    
    ultimaFilaNueva = wsNueva.Cells(wsNueva.Rows.count, "A").End(xlUp).Row
    If ultimaFilaNueva < 6 Then ultimaFilaNueva = 6

    For i = 6 To ultimaFilaNueva
        If Trim(CStr(wsNueva.Cells(i, 2).Value)) <> "" Then
            nombreCompleto = Trim(CStr(wsNueva.Cells(i, 1).Value))
            
            Do While InStr(nombreCompleto, "  ") > 0
                nombreCompleto = Replace(nombreCompleto, "  ", " ")
            Loop
            
            If UBound(Split(nombreCompleto, " ")) >= 2 Then
                totalAlumnos = totalAlumnos + 1
            End If
        End If
    Next i
    
    Dim cabecera As String
    Dim NombreAsignatura As String: NombreAsignatura = wsOrigen.Range("E1")
    Dim Curso As String: Curso = wsOrigen.Range("C1")
    
    cabecera = "Nombre Asignatura: " & NombreAsignatura & vbCrLf & _
               "Curso: " & Curso & vbCrLf & _
               "Número total Alumnos: " & totalAlumnos

    With wsNueva.Range("D5:F9")
        .Merge
        .Value = cabecera
        .HorizontalAlignment = xlCenter: .VerticalAlignment = xlCenter
        .Font.bold = True: .Font.Size = 13
        .BorderAround LineStyle:=xlContinuous, Weight:=xlMedium
    End With

    wsNueva.Range("Z1").Value = colExamen
    wsNueva.Range("Z1").Font.Color = vbWhite
    wsNueva.Columns("A:B").AutoFit
    wsNueva.Columns("A:B").Hidden = True
    
    Set rng = wsNueva.Range("G1:J2")
    Set btnVer = wsNueva.Buttons.Add(rng.Left, rng.Top, rng.Width, rng.Height)
    With btnVer
        .Name = "BtnVerDatos": .Caption = "MOSTRAR LISTADO ALUMNOS Y CALIFICACIONES"
        .OnAction = "AlternarVisibilidadDatos"
        .Font.bold = True: .Font.Size = 11
    End With
    
    CopiarEstadisticaFinal wsOrigen, colExamen
    MsgBox "Generado " & wsNueva.Name
End Sub

Sub CopiarEstadisticaFinal(wsOrigen As Worksheet, colExamen As Long)
    Dim wsNueva As Worksheet
    Dim rngNombres As Range, rngValores As Range, rngPruebas As Range, rngTipoPruebas As Range
