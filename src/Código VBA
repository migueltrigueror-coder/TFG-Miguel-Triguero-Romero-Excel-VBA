        End If
        
        txtInforme = txtInforme & "Su nota media acumulada actual es de |" & Format(mPondA, "0.00") & "| (sobre 10 puntos máximos). A día de hoy, y a falta de |" & (5 - totalPruebasRealizadas) & _
                     " actividades evaluadoras| (entre exámenes y actividades complementarias), con un peso pendiente de evaluar de |" & (100 - pesoEvaluado) & "%|, " & _
                     fraseAccion & " en el resto de las actividades pendientes para aprobar la asignatura." & vbCrLf & vbCrLf
