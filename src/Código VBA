Sub ExportarInformePDF()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim rutaCarpeta As String, nombreArchivo As String
    
    If ThisWorkbook.Path = "" Then
        MsgBox "Por favor, guarde primero su archivo de Excel en una carpeta.", vbCritical, "Error de Ruta"
        Exit Sub
    End If

    rutaCarpeta = ThisWorkbook.Path & "\"
    nombreArchivo = ws.Name & ".pdf"
    
    Application.ScreenUpdating = False
    With ws.PageSetup
        .PrintArea = "$G$4:$AR$40"
        .Orientation = xlLandscape
        .PaperSize = xlPaperA4
        .Zoom = False
        .FitToPagesWide = 1
        .FitToPagesTall = 1
        .CenterHorizontally = True
        .CenterVertically = True
    End With
    
    On Error Resume Next
    ws.Range("G4:AR40").ExportAsFixedFormat _
        Type:=xlTypePDF, _
        Filename:=rutaCarpeta & nombreArchivo, _
        OpenAfterPublish:=True
    
    If Err.Number = 0 Then
        MsgBox "Generado:" & vbCrLf & nombreArchivo, vbInformation
    Else
        MsgBox "Error: No se pudo generar el PDF. Compruebe si el archivo ya está abierto.", vbCritical
    End If
    On Error GoTo 0
    Application.ScreenUpdating = True
End Sub

Sub GenerarCajasyBigotes()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim lastRow As Long, rngDatos As Range
    Dim Q1 As Double, q2 As Double, Q3 As Double, minVal As Double, maxVal As Double
    Dim shpChart As Shape, nombreGrafico As String: nombreGrafico = "BoxPlotHorizontal"

    lastRow = ws.Cells(ws.Rows.count, "B").End(xlUp).Row
    If lastRow < 6 Then Exit Sub
    Set rngDatos = ws.Range("B6:B" & lastRow)

    minVal = Application.WorksheetFunction.Min(rngDatos): maxVal = Application.WorksheetFunction.Max(rngDatos)
    Q1 = Application.WorksheetFunction.Quartile_Exc(rngDatos, 1)
    q2 = Application.WorksheetFunction.Median(rngDatos)
    Q3 = Application.WorksheetFunction.Quartile_Exc(rngDatos, 3)

    On Error Resume Next: ws.ChartObjects(nombreGrafico).Delete: On Error GoTo 0

    Set shpChart = ws.Shapes.AddChart2(-1, xlBarStacked, Left:=ws.Range("H25").Left, Top:=ws.Range("H25").Top, Width:=480, Height:=250)
