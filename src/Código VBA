Sub CrearGraficoEvolucionAlumno(ws As Worksheet, nombreAlumno As String)
    Dim chartObj As ChartObject
    Dim serAlumno As Series, serClase As Series
    Dim i As Integer
    Dim notaAlumno As Variant, mediaClase As Variant
    Dim zScore As Double, desvClase As Double
    Dim xInicioPlot As Double, anchoPlot As Double, xPunto As Double
    Dim yEjeZ As Double, altoEscalaZ As Double, anchoBarraZ As Double
    Dim anchoSeccion As Double, offsetInicial As Double
    Dim shpBarra As Shape, colorBarra As Long
    Dim ajusteManual As Double: ajusteManual = 4.5
    
    Dim shpContenedor As Shape
    Dim topContenedor As Double, altoContenedor As Double
    topContenedor = ws.Rows(21).Top
    altoContenedor = ws.Rows(43).Top - topContenedor
    
    Set shpContenedor = ws.Shapes.AddShape(msoShapeRectangle, ws.Cells(21, 2).Left, topContenedor, 500, altoContenedor)
    With shpContenedor: .Fill.ForeColor.RGB = RGB(240, 240, 240): .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 3: End With

Set chartObj = ws.ChartObjects.Add(Left:=ws.Cells(21, 2).Left, Top:=ws.Cells(22, 2).Top, Width:=500, Height:=160)
    
    With chartObj.Chart
        .ChartType = xlLineMarkers
        .DisplayBlanksAs = xlNotPlotted
        .ChartArea.Format.Fill.Visible = msoFalse
        .ChartArea.Format.Line.Visible = msoFalse
        .PlotArea.Format.Fill.Visible = msoFalse
        Do While .SeriesCollection.count > 0: .SeriesCollection(1).Delete: Loop
        
        Dim arrAlumno(1 To 5) As Variant
        Dim arrClase(1 To 5) As Variant
        Dim hayDatosAlumno As Boolean: hayDatosAlumno = False
        Dim hayDatosClase As Boolean: hayDatosClase = False
        
        For i = 1 To 5
            notaAlumno = ws.Cells(4, i).Value
            If IsNumeric(notaAlumno) And notaAlumno > 0 Then
                arrAlumno(i) = notaAlumno
                hayDatosAlumno = True
            Else
                arrAlumno(i) = CVErr(xlErrNA)
            End If
            
            mediaClase = ws.Cells(1, 26 + i).Value
            If IsNumeric(mediaClase) And mediaClase > 0 And InStr(1, mediaClase, "Faltan", vbTextCompare) = 0 Then
                arrClase(i) = mediaClase
                hayDatosClase = True
            Else
                arrClase(i) = CVErr(xlErrNA)
            End If
        Next i

        If hayDatosAlumno Then
            Set serAlumno = .SeriesCollection.NewSeries
            With serAlumno
                .Name = "Progreso Alumno"
                .XValues = ws.Range("A3:E3")
                .Values = arrAlumno
                .MarkerStyle = xlMarkerStyleCircle: .MarkerSize = 6
                .MarkerBackgroundColor = RGB(46, 117, 182)
                .HasDataLabels = True
                With .DataLabels
                    .Format.TextFrame2.TextRange.Font.Size = 9
                    .Format.TextFrame2.TextRange.Font.bold = msoTrue
                    .Format.TextFrame2.TextRange.Font.Fill.ForeColor.RGB = RGB(46, 117, 182)
                    .NumberFormat = "0,00"
                End With
                With .Format.Line: .ForeColor.RGB = RGB(46, 117, 182): .Weight = 1.75: .DashStyle = msoLineDash: End With
            End With
        End If

        If hayDatosClase Then
            Set serClase = .SeriesCollection.NewSeries
            With serClase
                .Name = "Media Clase"
                .Values = arrClase
                .MarkerStyle = xlMarkerStyleSquare: .MarkerSize = 6
                .MarkerBackgroundColor = RGB(128, 128, 128)
                .HasDataLabels = True
                With .DataLabels
                    .Format.TextFrame2.TextRange.Font.Size = 9
                    .Format.TextFrame2.TextRange.Font.bold = msoTrue
                    .Format.TextFrame2.TextRange.Font.Fill.ForeColor.RGB = RGB(128, 128, 128)
                    .NumberFormat = "0,00"
                End With
                With .Format.Line: .ForeColor.RGB = RGB(150, 150, 150): .Weight = 1.25: End With
            End With
        End If

        If hayDatosAlumno And hayDatosClase Then
            For i = 1 To 5
                Dim vAlu As Double: vAlu = 0
                Dim vCla As Double: vCla = 0
                
                If IsNumeric(arrAlumno(i)) Then vAlu = arrAlumno(i)
                If IsNumeric(arrClase(i)) Then vCla = arrClase(i)
                
                If vAlu <> 0 And vCla <> 0 Then
                    If vAlu >= vCla Then
                        serAlumno.Points(i).DataLabel.Position = xlLabelPositionAbove
                        serClase.Points(i).DataLabel.Position = xlLabelPositionBelow
                    Else
                        serAlumno.Points(i).DataLabel.Position = xlLabelPositionBelow
                        serClase.Points(i).DataLabel.Position = xlLabelPositionAbove
                    End If
                End If
            Next i
        End If

        With .Axes(xlCategory): .Format.Line.ForeColor.RGB = RGB(0, 0, 0): .Format.Line.Weight = 3: End With
        With .Axes(xlValue): .MinimumScale = 0: .MaximumScale = 10: .Format.Line.ForeColor.RGB = RGB(0, 0, 0): .Format.Line.Weight = 3: .HasMajorGridlines = False: End With
        .HasTitle = True: .ChartTitle.Text = "Evolución de Notas: " & nombreAlumno
        .HasLegend = True: .legend.Position = xlLegendPositionBottom
    End With

    yEjeZ = ws.Rows(38).Top: xInicioPlot = chartObj.Left + chartObj.Chart.PlotArea.InsideLeft
    anchoPlot = chartObj.Chart.PlotArea.InsideWidth: anchoSeccion = anchoPlot / 5: offsetInicial = anchoSeccion / 2
    altoEscalaZ = 18: anchoBarraZ = 14

    With ws.Shapes.AddLine(xInicioPlot, yEjeZ, xInicioPlot + anchoPlot, yEjeZ).Line
        .ForeColor.RGB = RGB(0, 0, 0): .Weight = 3
    End With

    For i = 1 To 5
        notaAlumno = ws.Cells(4, i).Value
        mediaClase = ws.Cells(1, 26 + i).Value
        
        If IsNumeric(notaAlumno) And IsNumeric(mediaClase) And notaAlumno > 0 And mediaClase > 0 Then
            xPunto = xInicioPlot + offsetInicial + ((i - 1) * anchoSeccion) + ajusteManual
            desvClase = ws.Cells(2, 26 + i).Value
            zScore = IIf(desvClase > 0, (notaAlumno - mediaClase) / desvClase, 0)
            
            With ws.Shapes.AddLine(xPunto, ws.Rows(23).Top, xPunto, ws.Rows(41).Top).Line
                .DashStyle = msoLineDash: .ForeColor.RGB = RGB(0, 0, 0): .Weight = 1: .Transparency = 0.7
            End With

            If zScore >= 0 Then
                Set shpBarra = ws.Shapes.AddShape(msoShapeRectangle, xPunto - (anchoBarraZ / 2), yEjeZ - (zScore * altoEscalaZ), anchoBarraZ, zScore * altoEscalaZ)
                colorBarra = RGB(0, 176, 80)
            Else
                Set shpBarra = ws.Shapes.AddShape(msoShapeRectangle, xPunto - (anchoBarraZ / 2), yEjeZ, anchoBarraZ, Abs(zScore) * altoEscalaZ)
                colorBarra = RGB(192, 0, 0)
            End If
            With shpBarra: .Fill.ForeColor.RGB = colorBarra: .Line.Visible = msoFalse: End With

            With ws.Shapes.AddTextbox(msoTextOrientationHorizontal, xPunto - 20, IIf(zScore >= 0, yEjeZ - (zScore * altoEscalaZ) - 15, yEjeZ + (Abs(zScore) * altoEscalaZ) + 2), 40, 15)
                .TextFrame2.TextRange.Text = Format(zScore, "0.0")
                .TextFrame2.TextRange.Font.Size = 9: .TextFrame2.TextRange.Font.bold = msoTrue
                .TextFrame2.TextRange.Font.Fill.ForeColor.RGB = colorBarra
                .TextFrame2.TextRange.ParagraphFormat.Alignment = msoAlignCenter
                .Fill.Visible = msoFalse: .Line.Visible = msoFalse
            End With
        End If
    Next i

    CrearDashboardIndicadores ws
End Sub

Sub AñadirBarraConsistencia(ws As Worksheet)
    Dim desvEst As Double, corrVal As Double, impactoVal As Double
    Dim anchoMax As Double, altoBarra As Double, altoContenedor As Double, anchoContenedor As Double, topContenedor As Double
    Dim leftPos As Double, topPos As Double, startBarraX As Double
    Dim shpContenedor As Shape, shpBarraFondo As Shape
    Dim colorBarra1 As Long, colorBarra2 As Long, colorImpacto As Long
    Dim porc1 As Double, porc2 As Double
    Dim centroX As Double, anchoRelleno As Double
    Dim gapSeccion As Double, offsetVertical As Double, altoTotalContenido As Double
    Dim numBarras As Integer, cursorY As Double
    
    Dim notasExistentes As Long
    notasExistentes = Application.WorksheetFunction.count(ws.Range("A4:E4"))
    
    If notasExistentes < 5 Then
        numBarras = 2
        altoBarra = 45
        gapSeccion = 45
    Else
        numBarras = 3
        altoBarra = 35
        gapSeccion = 25
    End If

    topContenedor = ws.Rows(21).Top
    altoContenedor = ws.Rows(43).Top - topContenedor
    anchoContenedor = 500
    anchoMax = 300
    leftPos = ws.Range("F21").Left - 45
    topPos = topContenedor
    
    On Error Resume Next
    desvEst = Application.WorksheetFunction.StDev_P(ws.Range("A4:E4"))
    corrVal = Application.WorksheetFunction.Correl(ws.Range("A2:E2"), ws.Range("A4:E4"))
    impactoVal = ws.Range("A14").Value
    If Err.Number <> 0 Then corrVal = 0
    On Error GoTo 0
    
    porc1 = (5 - desvEst) / 5: If porc1 < 0.05 Then porc1 = 0.05: If porc1 > 1 Then porc1 = 1
    Select Case desvEst
        Case Is > 3: colorBarra1 = RGB(255, 0, 0)
        Case 1.5 To 3: colorBarra1 = RGB(255, 192, 0)
        Case 0.75 To 1.5: colorBarra1 = RGB(0, 176, 80)
        Case Is < 0.75: colorBarra1 = RGB(60, 135, 204)
    End Select
    
    porc2 = (corrVal + 1) / 2
    Select Case corrVal
        Case Is < -0.5: colorBarra2 = RGB(255, 0, 0)
        Case -0.5 To 0: colorBarra2 = RGB(255, 192, 0)
        Case 0 To 0.5: colorBarra2 = RGB(0, 176, 80)
        Case Is > 0.5: colorBarra2 = RGB(60, 135, 204)
    End Select

    Set shpContenedor = ws.Shapes.AddShape(msoShapeRectangle, leftPos, topPos, anchoContenedor, altoContenedor)
    With shpContenedor
        .Fill.ForeColor.RGB = RGB(235, 235, 235)
        .Line.ForeColor.RGB = RGB(150, 150, 150)
        .Line.Weight = 3
    End With

    altoTotalContenido = (20 * numBarras) + (altoBarra * numBarras) + (gapSeccion * (numBarras - 1))
    If numBarras = 3 Then altoTotalContenido = altoTotalContenido + 15
    
    offsetVertical = (altoContenedor - altoTotalContenido) / 2
    startBarraX = leftPos + (anchoContenedor - anchoMax) / 2
    cursorY = topPos + offsetVertical

    CrearTexto ws, "Análisis de Consistencia", leftPos, cursorY, anchoContenedor, 20, 11, True
    cursorY = cursorY + 25
    Set shpBarraFondo = ws.Shapes.AddShape(msoShapeRectangle, startBarraX, cursorY, anchoMax, altoBarra)
    With shpBarraFondo: .Fill.ForeColor.RGB = RGB(255, 255, 255): .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 1.5: End With
    With ws.Shapes.AddShape(msoShapeRectangle, startBarraX, cursorY, anchoMax * porc1, altoBarra)
        .Fill.ForeColor.RGB = colorBarra1: .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 1.5
    End With
    CrearTexto ws, "Poca consistencia", startBarraX - 95, cursorY, 90, altoBarra, 8, False, msoAlignRight
    CrearTexto ws, "Mucha consistencia", startBarraX + anchoMax + 5, cursorY, 90, altoBarra, 8, False, msoAlignLeft

    cursorY = cursorY + altoBarra + gapSeccion
    CrearTexto ws, "Rendimiento bajo presión (Correlación)", leftPos, cursorY, anchoContenedor, 20, 11, True
    cursorY = cursorY + 25
    Set shpBarraFondo = ws.Shapes.AddShape(msoShapeRectangle, startBarraX, cursorY, anchoMax, altoBarra)
    With shpBarraFondo: .Fill.ForeColor.RGB = RGB(255, 255, 255): .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 1.5: End With
    With ws.Shapes.AddShape(msoShapeRectangle, startBarraX, cursorY, anchoMax * porc2, altoBarra)
        .Fill.ForeColor.RGB = colorBarra2: .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 1.5
    End With
    CrearTexto ws, "Poco rendimiento", startBarraX - 95, cursorY, 90, altoBarra, 8, False, msoAlignRight
    CrearTexto ws, "Buen rendimiento", startBarraX + anchoMax + 5, cursorY, 90, altoBarra, 8, False, msoAlignLeft

If numBarras = 3 Then
        cursorY = cursorY + altoBarra + gapSeccion
        CrearTexto ws, "Impacto Actividades", leftPos, cursorY, anchoContenedor, 20, 11, True
        cursorY = cursorY + 25
        
        Set shpBarraFondo = ws.Shapes.AddShape(msoShapeRectangle, startBarraX, cursorY, anchoMax, altoBarra)
        With shpBarraFondo: .Fill.ForeColor.RGB = RGB(255, 255, 255): .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 1.5: End With
        
        centroX = startBarraX + (anchoMax / 2)
        anchoRelleno = (Abs(impactoVal) / 2.5) * (anchoMax / 2)
        If anchoRelleno > (anchoMax / 2) Then anchoRelleno = anchoMax / 2
        
        If impactoVal <> 0 Then
            Dim xRelleno As Double, xTxt As Double
            Dim alineacionTxt As MsoParagraphAlignment
            
            If impactoVal > 0 Then
                xRelleno = centroX: colorImpacto = RGB(0, 176, 80)
                xTxt = (centroX + anchoRelleno) - 32
                alineacionTxt = msoAlignRight
            Else
                xRelleno = centroX - anchoRelleno: colorImpacto = RGB(192, 0, 0)
                xTxt = xRelleno + 2
                alineacionTxt = msoAlignLeft
            End If
            
            With ws.Shapes.AddShape(msoShapeRectangle, xRelleno, cursorY, anchoRelleno, altoBarra)
                .Fill.ForeColor.RGB = colorImpacto: .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 1.5
            End With
            
            Dim shpTxt As Shape
            Set shpTxt = CrearTexto(ws, Format(impactoVal, "0.0"), xTxt, cursorY, 30, altoBarra, 9, True, alineacionTxt)
            shpTxt.TextFrame2.TextRange.Font.Fill.ForeColor.RGB = RGB(255, 255, 255)
        End If
        
        With ws.Shapes.AddLine(centroX, cursorY - 5, centroX, cursorY + altoBarra + 5).Line
            .ForeColor.RGB = RGB(0, 0, 0): .DashStyle = msoLineDash: .Weight = 1
        End With
        CrearTexto ws, "0", centroX - 10, cursorY + altoBarra + 2, 20, 15, 8, True
        CrearTexto ws, "Impacto negativo", startBarraX - 95, cursorY, 90, altoBarra, 8, False, msoAlignRight
        CrearTexto ws, "Impacto positivo", startBarraX + anchoMax + 5, cursorY, 90, altoBarra, 8, False, msoAlignLeft
    End If
End Sub

Function CrearTexto(ws As Worksheet, txt As String, x As Double, y As Double, w As Double, h As Double, sz As Integer, bold As Boolean, Optional alig As MsoParagraphAlignment = msoAlignCenter) As Shape
    Dim tempShp As Shape
    Set tempShp = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, x, y, w, h)
    
    With tempShp
        .TextFrame2.TextRange.Text = txt
        .TextFrame2.TextRange.Font.Size = sz
        .TextFrame2.TextRange.Font.bold = IIf(bold, msoTrue, msoFalse)
        .TextFrame2.TextRange.ParagraphFormat.Alignment = alig
        .TextFrame2.VerticalAnchor = msoAnchorMiddle
        .Fill.Visible = msoFalse
        .Line.Visible = msoFalse
    End With
    
    Set CrearTexto = tempShp
End Function

Sub CrearDashboardIndicadores(ws As Worksheet)
    Dim shpMedia As Shape, shpPercentil As Shape, shpNotaNec As Shape
    Dim shpBarraFondo As Shape, shpBarraProgreso As Shape
    Dim shpContenedor As Shape, shpMejor As Shape, shpPeor As Shape
    Dim valorMedia As Double, valorPercentil As Double, valorNotaNec As Variant
    Dim colorMedia As Long, colorPercentil As Long, colorNotaNec As Long
    Dim leftCont As Double, topCont As Double
    Dim anchoCont As Double: anchoCont = 500
    Dim altoCont As Double: altoCont = 260
    Dim tamCirculo As Double: tamCirculo = 120
    Dim nombresFormas() As String
    Dim count As Integer
    Dim colorFondoDashboard As Long
    
    colorFondoDashboard = RGB(235, 235, 235)
    
    valorMedia = ws.Range("F4").Value
    valorPercentil = ws.Range("B10").Value
    valorNotaNec = ws.Range("I14").Value
    
    leftCont = ws.Range("B45").Left
    topCont = ws.Range("B45").Top
    
    Select Case valorMedia: Case Is < 2.5: colorMedia = RGB(255, 0, 0): Case Is < 5: colorMedia = RGB(255, 192, 0): Case Is < 7.5: colorMedia = RGB(0, 176, 80): Case Else: colorMedia = RGB(60, 135, 204): End Select
    Select Case valorPercentil: Case Is < 0.25: colorPercentil = RGB(255, 0, 0): Case Is < 0.5: colorPercentil = RGB(255, 192, 0): Case Is < 0.75: colorPercentil = RGB(0, 176, 80): Case Else: colorPercentil = RGB(60, 135, 204): End Select
    Select Case True: Case valorNotaNec = "No Procede": colorNotaNec = RGB(0, 176, 80): Case valorNotaNec = "Necesita más de 10": colorNotaNec = RGB(255, 0, 0): Case IsNumeric(valorNotaNec): colorNotaNec = RGB(255, 192, 0): Case valorNotaNec = "va bien encaminado": colorNotaNec = RGB(0, 176, 80): Case Else: colorNotaNec = RGB(255, 255, 255): End Select

    Set shpContenedor = ws.Shapes.AddShape(msoShapeRectangle, leftCont, topCont, anchoCont, altoCont)
    With shpContenedor: .Fill.ForeColor.RGB = colorFondoDashboard: .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 3: .ZOrder msoSendToBack: End With
    count = 1: ReDim Preserve nombresFormas(1 To count): nombresFormas(count) = shpContenedor.Name

    Dim yInicioBloque As Double: yInicioBloque = topCont + 32
    Dim yPrincipal As Double: yPrincipal = yInicioBloque + 25
    Dim yEtiquetasFinales As Double: yEtiquetasFinales = yPrincipal + tamCirculo + 28

    Dim centroX1 As Double: centroX1 = leftCont + (anchoCont / 6) * 1 - (tamCirculo / 2)
    Dim centroX2 As Double: centroX2 = leftCont + (anchoCont / 6) * 3 - (50 / 2)
    Dim centroX3 As Double: centroX3 = leftCont + (anchoCont / 6) * 5 - (tamCirculo / 2)

    Set shpMedia = ws.Shapes.AddShape(msoShapeOval, centroX1, yPrincipal, tamCirculo, tamCirculo)
    count = count + 1: ReDim Preserve nombresFormas(1 To count): nombresFormas(count) = shpMedia.Name
    With shpMedia
        .Fill.ForeColor.RGB = colorMedia: .Line.ForeColor.RGB = RGB(0, 0, 0)
        With .TextFrame2.TextRange: .Text = Format(valorMedia, "0.00"): .Font.Size = 14: .Font.bold = msoTrue: .ParagraphFormat.Alignment = msoAlignCenter: End With
        .TextFrame2.VerticalAnchor = msoAnchorMiddle
    End With

    Set shpBarraFondo = ws.Shapes.AddShape(msoShapeRectangle, centroX2, yPrincipal, 50, tamCirculo)
    count = count + 1: ReDim Preserve nombresFormas(1 To count): nombresFormas(count) = shpBarraFondo.Name
    With shpBarraFondo: .Fill.Visible = msoFalse: .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 1.5: End With
    
    Dim altoRelleno As Double: altoRelleno = tamCirculo * valorPercentil
    If altoRelleno < 12 Then altoRelleno = 12
    Set shpBarraProgreso = ws.Shapes.AddShape(msoShapeRectangle, centroX2, yPrincipal + (tamCirculo - altoRelleno), 50, altoRelleno)
    count = count + 1: ReDim Preserve nombresFormas(1 To count): nombresFormas(count) = shpBarraProgreso.Name
    With shpBarraProgreso
        .Fill.ForeColor.RGB = colorPercentil: .Line.Visible = msoFalse
        With .TextFrame2.TextRange: .Text = Format(valorPercentil, "0%"): .Font.Size = 14: .Font.bold = msoTrue: .ParagraphFormat.Alignment = msoAlignCenter: End With
        .TextFrame2.VerticalAnchor = msoAnchorMiddle
    End With

    Set shpMejor = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, centroX2 - 35, yPrincipal - 22, 120, 20)
    count = count + 1: ReDim Preserve nombresFormas(1 To count): nombresFormas(count) = shpMejor.Name
    FormatearMini shpMejor, "Mejor alumno", colorFondoDashboard

    Set shpPeor = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, centroX2 - 35, yPrincipal + tamCirculo + 2, 120, 20)
    count = count + 1: ReDim Preserve nombresFormas(1 To count): nombresFormas(count) = shpPeor.Name
    FormatearMini shpPeor, "Peor alumno", colorFondoDashboard

    Set shpNotaNec = ws.Shapes.AddShape(msoShapeOval, centroX3, yPrincipal, tamCirculo, tamCirculo)
    count = count + 1: ReDim Preserve nombresFormas(1 To count): nombresFormas(count) = shpNotaNec.Name
    With shpNotaNec
        .Fill.ForeColor.RGB = colorNotaNec: .Line.ForeColor.RGB = RGB(0, 0, 0)
        Dim textoFormateado As String
        If IsNumeric(valorNotaNec) Then
            textoFormateado = Format(valorNotaNec, "0.00")
        Else
            textoFormateado = valorNotaNec
        End If
        
        With .TextFrame2.TextRange
            .Text = textoFormateado
            .Font.Size = 13
            .Font.bold = msoTrue
            .ParagraphFormat.Alignment = msoAlignCenter
            .Font.Fill.ForeColor.RGB = RGB(255, 255, 255)
        End With
        
        .TextFrame2.VerticalAnchor = msoAnchorMiddle
    End With

    count = count + 1: ReDim Preserve nombresFormas(1 To count)
    nombresFormas(count) = CrearEtiquetaLimpia(ws, "Nota media ponderada", centroX1 - 10, yEtiquetasFinales, tamCirculo + 20)
    
    count = count + 1: ReDim Preserve nombresFormas(1 To count)
    nombresFormas(count) = CrearEtiquetaLimpia(ws, "Percentil", centroX2 - 35, yEtiquetasFinales, 120)
    
    count = count + 1: ReDim Preserve nombresFormas(1 To count)
    nombresFormas(count) = CrearEtiquetaLimpia(ws, "Nota necesaria para aprobar", centroX3 - 10, yEtiquetasFinales, tamCirculo + 20)

    ws.Shapes.Range(nombresFormas).Group
    AñadirBarraConsistencia ws
    CrearGraficoComparativoMedias ws
End Sub

Sub FormatearMini(shp As Shape, txt As String, col As Long)
    With shp
        .Fill.ForeColor.RGB = col: .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 0.5
        With .TextFrame2.TextRange: .Text = txt: .Font.Size = 8: .Font.bold = msoTrue: .ParagraphFormat.Alignment = msoAlignCenter: End With
        .TextFrame2.MarginLeft = 0: .TextFrame2.MarginRight = 0: .TextFrame2.VerticalAnchor = msoAnchorMiddle
    End With
End Sub

Function CrearEtiquetaLimpia(ws As Worksheet, texto As String, L As Double, T As Double, w As Double) As String
    Dim tb As Shape
    Set tb = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, L, T, w, 40)
    With tb.TextFrame2
        .TextRange.Text = texto: .TextRange.Font.bold = msoTrue: .TextRange.Font.Size = 9: .TextRange.ParagraphFormat.Alignment = msoAlignCenter
        .MarginLeft = 0: .MarginRight = 0: .MarginTop = 0: .MarginBottom = 0: .VerticalAnchor = msoAnchorTop
    End With
    tb.Line.Visible = msoFalse: tb.Fill.Visible = msoFalse
    CrearEtiquetaLimpia = tb.Name
End Function

Sub CrearGraficoComparativoMedias(ws As Worksheet)
    Dim i As Integer
    Dim sumaExamenesClase As Double, sumaPruebasClase As Double
    Dim contExamenes As Integer, contPruebas As Integer
    Dim mediaExamenesClase As Double, mediaPruebasClase As Double
    Dim chartObj As ChartObject
    Dim txtBox As Shape
    
    If Application.WorksheetFunction.CountBlank(ws.Range("A4:E4")) > 0 Then
        
        Set txtBox = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, _
            ws.Range("F45").Left - 45, _
            ws.Range("F45").Top, _
            500, 260)
            
        With txtBox
            .Name = "AvisoFaltaDatos"
            .Fill.ForeColor.RGB = RGB(235, 235, 235)
            .Fill.Solid
            
            With .Line
                .Visible = msoTrue
                .ForeColor.RGB = RGB(0, 0, 0)
                .Weight = 3
            End With
            
            With .TextFrame2
                .TextRange.Text = "FALTAN CALIFICACIONES PARA PODER MOSTRAR ESTE GRÁFICO"
                .VerticalAnchor = msoAnchorMiddle
                
                With .TextRange.Font
                    .NameComplexScript = "Arial"
                    .NameFarEast = "Arial"
                    .Name = "Arial"
                    .Size = 20
                    .bold = msoTrue
                    .Fill.ForeColor.RGB = RGB(0, 0, 0)
                End With
                
                .TextRange.ParagraphFormat.Alignment = msoAlignCenter
            End With
        End With
        CrearGraficoParcialesVsFinal ws
        CrearContenedorPrincipal ws
        Exit Sub
    End If

    contExamenes = 0: contPruebas = 0
    sumaExamenesClase = 0: sumaPruebasClase = 0

    For i = 27 To 31
        Dim notaClase As Variant
        Dim tipoPrueba As String
        
        notaClase = ws.Cells(1, i).Value
        tipoPrueba = ws.Cells(3, i).Value
        
        If IsNumeric(notaClase) And notaClase > 0 Then
            If InStr(1, tipoPrueba, "Examen", vbTextCompare) > 0 Then
                sumaExamenesClase = sumaExamenesClase + notaClase
                contExamenes = contExamenes + 1
            ElseIf InStr(1, tipoPrueba, "Prueba Complementaria", vbTextCompare) > 0 Then
                sumaPruebasClase = sumaPruebasClase + notaClase
                contPruebas = contPruebas + 1
            End If
        End If
    Next i
    
    mediaExamenesClase = IIf(contExamenes > 0, sumaExamenesClase / contExamenes, 0)
    mediaPruebasClase = IIf(contPruebas > 0, sumaPruebasClase / contPruebas, 0)
    Set chartObj = ws.ChartObjects.Add(Left:=ws.Range("F45").Left - 45, Top:=ws.Range("F45").Top, Width:=330, Height:=260)
    
    With chartObj.Chart
        .ChartType = xlColumnClustered
        
        .ChartArea.Format.Fill.ForeColor.RGB = RGB(235, 235, 235)
        With .ChartArea.Format.Line
            .Visible = msoTrue
            .ForeColor.RGB = RGB(0, 0, 0)
            .Weight = 3
        End With
        
        With .PlotArea.Format
            .Fill.ForeColor.RGB = RGB(255, 255, 255)
            .Fill.Solid
        End With

        .HasTitle = True
        .ChartTitle.Text = "Comparativa por Bloques: Alumno vs Clase"
        .ChartTitle.Format.TextFrame2.TextRange.Font.Size = 12
        .ChartTitle.Format.TextFrame2.TextRange.Font.bold = msoTrue
        
        Do While .SeriesCollection.count > 0: .SeriesCollection(1).Delete: Loop
        
        With .SeriesCollection.NewSeries
            .Name = "Alumno"
            .Values = Array(ws.Range("C10").Value, ws.Range("F10").Value)
            .XValues = Array("Exámenes", "Pruebas Comp.")
            .Format.Fill.ForeColor.RGB = RGB(46, 117, 182)
        End With
        
        With .SeriesCollection.NewSeries
            .Name = "Media Clase"
            .Values = Array(mediaExamenesClase, mediaPruebasClase)
            .Format.Fill.ForeColor.RGB = RGB(165, 165, 165)
        End With
        
        With .Axes(xlValue)
            .MinimumScale = 0
            .MaximumScale = 10
            .MajorUnit = 2
            .HasMajorGridlines = True
            .MajorGridlines.Format.Line.ForeColor.RGB = RGB(220, 220, 220)
            .Format.Line.Visible = msoTrue
            .Format.Line.ForeColor.RGB = RGB(0, 0, 0)
            .Format.Line.Weight = 1
        End With

        With .Axes(xlCategory)
            .Format.Line.Visible = msoTrue
            .Format.Line.ForeColor.RGB = RGB(0, 0, 0)
            .Format.Line.Weight = 1
        End With
        
        .HasLegend = True
        .legend.Position = xlLegendPositionBottom
        
        Dim ser As Series
        For Each ser In .SeriesCollection
            ser.HasDataLabels = True
            With ser.DataLabels
                .NumberFormat = "0,00"
                .Font.bold = True
                .Font.Size = 9
                .Position = xlLabelPositionOutsideEnd
            End With
        Next ser
    End With
    CrearGraficoParcialesVsFinal ws
End Sub

