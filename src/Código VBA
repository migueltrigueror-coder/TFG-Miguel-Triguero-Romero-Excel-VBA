Sub AñadirCuadrosAnalisisDinamico()
    Dim ws As Worksheet
    Dim lastRow As Long, numAlumnos As Long, n27 As Long
    Dim i As Integer
    Dim media As Double, Mediana As Double, desvTip As Double, Q1 As Double, Q3 As Double, iqr As Double
    Dim vAsimetria As Double, vCurtosis As Double, vMediaRec As Double, CoefVariacion As Double
    Dim mediaTop27 As Double, mediaBottom27 As Double, discIndice As Double
    Dim indiceDificultad As Double, porcentajeAprobados As Double, porcentajeSuspensos As Double
    Dim txtBox1 As Shape, txtBox2 As Shape, txtBox3 As Shape, txtBox4 As Shape
    Dim mensaje As String, calificacion As String, alertaSuspensos As String, formaCurva As String, DesviacionGrupo As String


    Set ws = ActiveSheet
    lastRow = ws.Cells(ws.Rows.count, "B").End(xlUp).Row
    If lastRow < 6 Then Exit Sub
    Dim rngDatos As Range: Set rngDatos = ws.Range("B6:B" & lastRow)
    numAlumnos = rngDatos.count

    media = Application.WorksheetFunction.Average(rngDatos)
    Mediana = Application.WorksheetFunction.Median(rngDatos)
    desvTip = Application.WorksheetFunction.StDev_S(rngDatos)
    vAsimetria = Application.WorksheetFunction.Skew(rngDatos)
    vCurtosis = Application.WorksheetFunction.Kurt(rngDatos)
    vMediaRec = Application.WorksheetFunction.TrimMean(rngDatos, 0.1)
    
    Dim MediaSuspensosLocal As Double
    On Error Resume Next
    MediaSuspensosLocal = Application.WorksheetFunction.AverageIf(rngDatos, "<5")
    On Error GoTo 0
    
    CoefVariacion = desvTip / media
    Q1 = Application.WorksheetFunction.Quartile_Exc(rngDatos, 1)
    Q3 = Application.WorksheetFunction.Quartile_Exc(rngDatos, 3)
    iqr = Q3 - Q1
    
    indiceDificultad = media / 10
    porcentajeAprobados = Application.WorksheetFunction.CountIf(rngDatos, ">=5") / numAlumnos
    porcentajeSuspensos = Application.WorksheetFunction.CountIf(rngDatos, "<5") / numAlumnos
    
    Dim celda As Range
    Dim sumaTop As Double, sumaBottom As Double
    Dim contTop As Long, contBottom As Long
    Dim p73 As Double, p27 As Double
    
    On Error Resume Next
    p73 = Application.WorksheetFunction.Percentile_Exc(ws.Range("B6:B" & lastRow), 0.73)
    p27 = Application.WorksheetFunction.Percentile_Exc(ws.Range("B6:B" & lastRow), 0.27)
    On Error GoTo 0
    
    For Each celda In ws.Range("B6:B" & lastRow)
        If IsNumeric(celda.Value) And Not IsEmpty(celda) Then
            If celda.Value > p73 Then
                sumaTop = sumaTop + celda.Value
                contTop = contTop + 1
            End If
            If celda.Value < p27 Then
                sumaBottom = sumaBottom + celda.Value
                contBottom = contBottom + 1
            End If
        End If
    Next celda
    
    If contTop > 0 Then mediaTop27 = sumaTop / contTop Else mediaTop = 0
    If contBottom > 0 Then mediaBottom27 = sumaBottom / contBottom Else mediaBottom = 0
    discIndice = (mediaTop27 - mediaBottom27) / 10
    
    Dim suspensos As Long: suspensos = numAlumnos - Application.WorksheetFunction.CountIf(rngDatos, ">=5")
    Dim mediaSus As Double: mediaSus = IIf(suspensos > 0, MediaSuspensosLocal, 0)
    
    Select Case media
        Case Is <= 5:    calificacion = "Insuficiente"
        Case 5 To 6.99:  calificacion = "Suficiente"
        Case 7 To 8.99:  calificacion = "Notable"
        Case Else:       calificacion = "Sobresaliente"
    End Select
    
    If suspensos = 0 Then
        alertaSuspensos = "Situación ideal: Sin alumnos suspensos."
    ElseIf mediaSus < 3 And porcentajeSuspensos < 0.2 Then
        alertaSuspensos = "Los suspensos tienen notas muy bajas, Media Suspensos: (" & Format(mediaSus, "0.0") & "). Tutoría Urgente."
    ElseIf mediaSus >= 3 And porcentajeSuspensos <= 0.4 Then
        alertaSuspensos = "Los suspensos tienen notas cercanas al aprobado, Media Suspensos: (" & Format(mediaSus, "0.0") & "). Repaso teórico necesario."
    ElseIf porcentajeSuspensos > 0.4 Then
        alertaSuspensos = "Elevado volumen de suspensos (" & Format(porcentajeSuspensos, "0%") & "). Revisar metodología."
    Else
        alertaSuspensos = "Los suspensos son recuperables."
    End If
    mensaje = IIf(vMediaRec - media > 0.4, "Los suspensos bajos hunden el promedio general.", "Los suspensos bajos no hunden el promedio general.")

    If Abs(vAsimetria) < 0.5 Then formaCurva = "Distribución Simétrica" Else _
    formaCurva = IIf(vAsimetria > 0, "Distribución con Sesgo Positivo (Difícil)", "Distribución con Sesgo Negativo (Fácil)")
    
    Dim tipoCurtosis As String
    If vCurtosis > 0.5 Then tipoCurtosis = "Distribución Leptocúrtica (Concentrada)" Else _
    tipoCurtosis = IIf(vCurtosis < -0.5, "Distribución Platicúrtica (Dispersa)", "Distribución Mesocúrtica (Normal)")

    If CoefVariacion > 3 Then
        DispersionGrupo = "Grupo muy heterogéneo. Una sola estrategia de clase no es útil"
    Else
        DispersionGrupo = "Grupo muy homogéneo. Una sola estrategia de clase es útil"
    End If

    If desvTip > 3 And iqr < 1 Then
        DesviacionGrupo = "El centro del grupo está muy unido pero hay outliers que afectan a la estadística."
    ElseIf desvTip < 1 And iqr < 1 Then
        DesviacionGrupo = "El grupo es muy homogéneo."
    ElseIf desvTip > 3 And iqr > 3 Then
        DesviacionGrupo = "El grupo está muy disperso."
    ElseIf desvTip < 1 And iqr > 3 Then
        DesviacionGrupo = "El grupo tiene una distribución asimétrica."
    Else
        DesviacionGrupo = "Distribución de dispersión estándar."
    End If
        

    On Error Resume Next
    ws.Shapes("CuadroAnalisis_General").Delete
    ws.Shapes("CuadroAnalisis_Tecnico").Delete
    ws.Shapes("CuadroAnalisis_Diversidad").Delete
    ws.Shapes("CuadroAnalisis_Riesgo").Delete
    On Error GoTo 0

    Set txtBox1 = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, ws.Range("AA8").Left + 15, ws.Range("AA8").Top, 390, 10)
    txtBox1.Name = "CuadroAnalisis_General"
    ConfigurarEstiloCuadro txtBox1, "Rendimiento Global:" & vbCrLf & vbCrLf & _
                           "Resumen General: " & calificacion & vbCrLf & _
                           "Media: " & Format(media, "0.00") & " | Mediana: " & Format(Mediana, "0.00") & vbCrLf & _
                           "Aprobados: " & Format(porcentajeAprobados, "0%") & " (" & (numAlumnos - suspensos) & " alumnos)" & vbCrLf & _
                           "Análisis Suspensos: " & alertaSuspensos & vbCrLf & _
                           "Tendencia: " & mensaje

    Set txtBox2 = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, ws.Range("AA15").Left + 15, ws.Range("AA15").Top, 390, 10)
    txtBox2.Name = "CuadroAnalisis_Tecnico"
    ConfigurarEstiloCuadro txtBox2, "Métricas de Calidad y Calibración:" & vbCrLf & vbCrLf & _
                           "Índice Dificultad: " & Format(indiceDificultad, "0.00") & " | Discriminación: " & Format(discIndice, "0.00") & vbCrLf & _
                           "Asimetría: " & Format(vAsimetria, "0.000") & " (" & formaCurva & ")" & vbCrLf & _
                           "Curtosis: " & Format(vCurtosis, "0.000") & " (" & tipoCurtosis & ")"

    Set txtBox3 = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, ws.Range("AA20").Left + 15, ws.Range("AA20").Top + 15, 390, 10)
    txtBox3.Name = "CuadroAnalisis_Diversidad"
    ConfigurarEstiloCuadro txtBox3, "Métricas de Diversidad y Cohesión:" & vbCrLf & vbCrLf & _
                           "Dispersión: " & DispersionGrupo & vbCrLf & _
                           "Desviación: " & DesviacionGrupo & vbCrLf & _
                           "Coef. Variación: " & Format(CoefVariacion, "0.00")

End Sub

