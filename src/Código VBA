Sub ExportarInformePDFAlumno()
    Dim wsOrigen As Worksheet: Set wsOrigen = ActiveSheet
    Dim wsTemp As Worksheet
    Dim shpContenedor As Shape
    Dim rutaCarpeta As String, nombreArchivo As String
    
    On Error Resume Next
    Set shpContenedor = wsOrigen.Shapes("MarcoDashboardPrincipal")
    On Error GoTo 0
    
    If shpContenedor Is Nothing Then
        MsgBox "No se encontró el marco 'MarcoDashboardPrincipal'.", vbCritical: Exit Sub
    End If

    rutaCarpeta = ThisWorkbook.Path & "\"
    nombreArchivo = wsOrigen.Name & ".pdf"
    
    Application.ScreenUpdating = False

    wsOrigen.Copy After:=Sheets(Sheets.count)
    Set wsTemp = ActiveSheet
    With wsTemp
        On Error Resume Next
        With .Range("I1:J500")
            .Value = ""
            .Font.Color = vbWhite
            .Interior.Color = vbWhite
            .Borders.LineStyle = xlNone
        End With
        On Error GoTo 0
        
        .Columns("I").ColumnWidth = 8
        .Columns("J").ColumnWidth = 4
        
        With .PageSetup
            .PrintArea = "$A$16:$Q$64"
            .Orientation = xlLandscape
            .PaperSize = xlPaperA4
            
            .LeftMargin = Application.InchesToPoints(0.3)
            .RightMargin = Application.InchesToPoints(0.3)
            .TopMargin = Application.InchesToPoints(0.3)
            .BottomMargin = Application.InchesToPoints(0.3)
            
            .CenterHorizontally = True
            .CenterVertically = True
            
            .Zoom = False
            .FitToPagesWide = 1
            .FitToPagesTall = 1
        End With

        On Error Resume Next
        .ExportAsFixedFormat _
            Type:=xlTypePDF, _
            Filename:=rutaCarpeta & nombreArchivo, _
            Quality:=xlQualityStandard, _
            OpenAfterPublish:=True
        
        If Err.Number = 0 Then
        MsgBox "Generado:" & vbCrLf & nombreArchivo, vbInformation
    Else
        MsgBox "Error: No se pudo generar el PDF. Compruebe si el archivo ya está abierto.", vbCritical
    End If
    On Error GoTo 0
    End With

    Application.DisplayAlerts = False
    wsTemp.Delete
    Application.DisplayAlerts = True
    
    wsOrigen.Activate
    Application.ScreenUpdating = True
    
End Sub

