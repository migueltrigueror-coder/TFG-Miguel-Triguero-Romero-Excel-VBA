Sub MacroInformeAlumnoFilaHorizontal()
    Dim wsDatos As Worksheet
    Dim filaBoton As Long
    Dim nombreAlumno As String
    Dim objBoton As Object
    
    Set wsDatos = ActiveSheet
    Application.ScreenUpdating = False
    On Error Resume Next
    Set objBoton = wsDatos.Shapes(Application.Caller)
    On Error GoTo 0
    
    If Not objBoton Is Nothing Then
        filaBoton = objBoton.TopLeftCell.Row
        nombreAlumno = wsDatos.Cells(filaBoton, 3).Value
        
        If nombreAlumno = "" Then
            MsgBox "No hay nombre en la columna 3 de esta fila.", vbExclamation
            Exit Sub
        End If
        
        GenerarTablaHorizontalAlumno wsDatos, filaBoton, nombreAlumno
    Else
        MsgBox "Error: Asigna esta macro a un botón de formulario.", vbCritical
    End If
End Sub

Sub GenerarTablaHorizontalAlumno(wsOrigen As Worksheet, filaAlumno As Long, nombreAlumno As String)
    Dim wsNueva As Worksheet
    Dim nombreHoja As String
    Dim i As Long, colDestino As Long
    
    nombreHoja = "Informe " & Left(nombreAlumno, 20)
    On Error Resume Next
    Set wsNueva = ThisWorkbook.Sheets(nombreHoja)
    If wsNueva Is Nothing Then
        Set wsNueva = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.count))
        wsNueva.Name = nombreHoja
    Else
        wsNueva.Cells.Clear
        wsNueva.Cells.UnMerge
    End If
    On Error GoTo 0
    
    On Error Resume Next
    Application.DisplayAlerts = False
    ThisWorkbook.Sheets(nombreHoja).Delete
    Application.DisplayAlerts = True
    On Error GoTo 0
    
    Set wsNueva = ThisWorkbook.Sheets.Add(After:=ThisWorkbook.Sheets(ThisWorkbook.Sheets.count))
    wsNueva.Name = nombreHoja
    With wsNueva.Range("A1:H1")
        .Merge
        .Value = "INFORME DE NOTAS: " & nombreAlumno
        .HorizontalAlignment = xlCenter
