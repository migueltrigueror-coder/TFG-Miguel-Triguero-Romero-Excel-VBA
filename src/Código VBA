    ElseIf ws.Range("F4").Value > wsNotas.Range("I138").Value Then
        txtInforme = txtInforme & "Con las calificaciones actuales, el alumno sigue el perfil de |Top 10% en el examen final|."
    ElseIf ws.Range("F4").Value < wsNotas.Range("I137").Value And ws.Range("F4").Value > wsNotas.Range("I136").Value And cv < 0.1 Then
        txtInforme = txtInforme & "Con las calificaciones actuales, el alumno sigue el perfil de |Alumno Constante Medio|."
