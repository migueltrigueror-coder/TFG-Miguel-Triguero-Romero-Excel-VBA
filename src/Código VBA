            With .Format.Line: .Visible = msoTrue: .ForeColor.RGB = RGB(0, 0, 0): .Weight = 2.25: End With
            .HasErrorBars = True
            .ErrorBar Direction:=xlX, Include:=xlPlusValues, Type:=xlCustom, Amount:=Array(maxVal - Q3)
            .ErrorBars.Format.Line.Weight = 2.25: .ErrorBars.Format.Line.ForeColor.RGB = RGB(0, 0, 0)
        End With

        .ChartGroups(1).HasSeriesLines = True
        With .ChartGroups(1).SeriesLines.Format.Line: .ForeColor.RGB = RGB(0, 0, 0): .Weight = 2.25: End With

        .Refresh: DoEvents
        Dim plL As Double: plL = .PlotArea.InsideLeft
        Dim plW As Double: plW = .PlotArea.InsideWidth

        Dim yPos1 As Double: yPos1 = 165
        Dim yPos2 As Double: yPos2 = 190

        AlinearEtiqueta shpChart, "Mín: " & Round(minVal, 2), minVal, plL, plW, yPos1
        AlinearEtiqueta shpChart, "Q1: " & Round(Q1, 2), Q1, plL, plW, yPos2
        AlinearEtiqueta shpChart, "Med: " & Round(q2, 2), q2, plL, plW, yPos1
        AlinearEtiqueta shpChart, "Q3: " & Round(Q3, 2), Q3, plL, plW, yPos2
        AlinearEtiqueta shpChart, "Máx: " & Round(maxVal, 2), maxVal, plL, plW, yPos1

        .HasLegend = False
    End With
End Sub

Sub AlinearEtiqueta(shp As Shape, txt As String, val As Double, pL As Double, pW As Double, yP As Double)
    Dim xPos As Double: xPos = pL + (val * pW / 10) - 37.5
    
    If val > 9.2 Then xPos = xPos - 25
    If val < 0.8 Then xPos = xPos + 15
    
    With shp.Chart.Shapes.AddTextbox(msoTextOrientationHorizontal, xPos, yP, 75, 20)
        .TextFrame2.TextRange.Text = txt
        .TextFrame2.TextRange.Font.Size = 8
        .TextFrame2.TextRange.Font.bold = msoTrue
        .TextFrame2.TextRange.Font.Fill.ForeColor.RGB = RGB(0, 0, 0)
        .TextFrame2.WordWrap = msoFalse
        .TextFrame2.AutoSize = msoAutoSizeNone
        .TextFrame2.TextRange.ParagraphFormat.Alignment = msoAlignCenter
        .Fill.Visible = msoFalse: .Line.Visible = msoFalse
    End With
End Sub

Sub GenerarCuadroRiesgo()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim lastRow As Long, i As Long
    Dim grupoActual As String, ultimoGrupoAñadido As String
    Dim contadorRiesgo As Integer: contadorRiesgo = 0
    Dim txtBox4 As Shape
    
    Dim grupos As Object: Set grupos = CreateObject("Scripting.Dictionary")
    
    lastRow = ws.Cells(ws.Rows.count, "B").End(xlUp).Row
    If lastRow < 6 Then Exit Sub

    For i = 6 To lastRow
        If InStr(1, ws.Cells(i, 1).Value, "Grupo", vbTextCompare) > 0 Then
            grupoActual = ws.Cells(i, 1).Value
        End If

        If IsNumeric(ws.Cells(i, 2).Value) And Not IsEmpty(ws.Cells(i, 2)) Then
            If ws.Cells(i, 2).Value < 3 Then
                If Not grupos.Exists(grupoActual) Then grupos.Add grupoActual, ""
                grupos(grupoActual) = grupos(grupoActual) & "• " & ws.Cells(i, 1).Value & ": " & Format(ws.Cells(i, 2).Value, "0.0") & vbCrLf
                contadorRiesgo = contadorRiesgo + 1
            End If
        End If
    Next i

    On Error Resume Next: ws.Shapes("CuadroAnalisis_Riesgo").Delete: On Error GoTo 0

    Dim colIzquierda As String, colDerecha As String
    Dim lineasIzquierda As Long, lineasDerecha As Long
    Dim clave As Variant, bloqueGrupo As String, numLineasBloque As Long
    
    For Each clave In grupos.Keys
        bloqueGrupo = "[" & UCase(clave) & "]" & vbCrLf & grupos(clave) & vbCrLf
        numLineasBloque = (Len(bloqueGrupo) - Len(Replace(bloqueGrupo, vbCrLf, ""))) / Len(vbCrLf)
        
        If lineasIzquierda <= lineasDerecha Then
            colIzquierda = colIzquierda & bloqueGrupo
            lineasIzquierda = lineasIzquierda + numLineasBloque
        Else
            colDerecha = colDerecha & bloqueGrupo
            lineasDerecha = lineasDerecha + numLineasBloque
        End If
    Next clave
    
    Dim listaFinal As String
    Dim arrIzq() As String, arrDer() As String
    arrIzq = Split(colIzquierda, vbCrLf)
    arrDer = Split(colDerecha, vbCrLf)
    
    Dim maxLineas As Long
    maxLineas = IIf(UBound(arrIzq) > UBound(arrDer), UBound(arrIzq), UBound(arrDer))
    
    For i = 0 To maxLineas
        Dim linea As String: linea = ""
        If i <= UBound(arrIzq) Then linea = arrIzq(i)
        If i <= UBound(arrDer) Then linea = linea & vbTab & arrDer(i)
        listaFinal = listaFinal & linea & vbCrLf
    Next i

    If contadorRiesgo = 0 Then listaFinal = "No se detectan alumnos con rendimiento crítico (< 3.0)."

    Set txtBox4 = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, _
                  ws.Range("AA26").Left + 15, ws.Range("AA26").Top, 390, 10)
    
    txtBox4.Name = "CuadroAnalisis_Riesgo"

    With txtBox4
        .Fill.ForeColor.RGB = RGB(255, 255, 255)
        .Line.ForeColor.RGB = IIf(contadorRiesgo > 0, RGB(192, 0, 0), RGB(0, 0, 0))
        .Line.Weight = IIf(contadorRiesgo > 0, 2, 1.2)
        
        With .TextFrame2
            .WordWrap = msoTrue
            .AutoSize = msoAutoSizeShapeToFitText
            .MarginLeft = 12: .MarginRight = 12: .MarginTop = 10: .MarginBottom = 10
            
            With .TextRange
                .Text = "Alumnos en Riesgo Crítico (Nota < 3.0):" & vbCrLf & vbCrLf & listaFinal
                .Font.Name = "Calibri"
                .Font.Size = 8.5
                
                With .Paragraphs(1): .Font.bold = msoTrue: .Font.Size = 11: .Font.UnderlineStyle = msoUnderlineSingleLine: End With

                Dim startPos As Long, endPos As Long
                Dim textoCompleto As String: textoCompleto = .Text
                startPos = InStr(1, textoCompleto, "[")
                
                Do While startPos > 0
                    endPos = InStr(startPos, textoCompleto, "]")
                    If endPos > 0 Then
                        .Characters(startPos, endPos - startPos + 1).Font.bold = msoTrue
                        startPos = InStr(endPos, textoCompleto, "[")
                    Else
                        Exit Do
                    End If
                Loop
                
                .ParagraphFormat.TabStops.Add msoTabStopLeft, 195
            End With
        End With
    End With
    VolverAlInicio
End Sub

Sub GenerarTextoEvaluacionExamen()
    Dim ws As Worksheet: Set ws = ActiveSheet
    Dim shp As Shape
    Dim txtExamen As String
    Dim rngCalificaciones As Range, rngNombres As Range, celda As Range
    Dim ultimaFila As Long
    
    Dim nombreExamen As String: nombreExamen = ws.Range("B4").Value
    Dim ponderacion As String: ponderacion = ws.Range("B5").Value & "%"
    
    Dim vMedia As Double: vMedia = IIf(IsError(ws.Range("E4").Value), 0, ws.Range("E4").Value)
    Dim vMediana As Double: vMediana = IIf(IsError(ws.Range("E5").Value), 0, ws.Range("E5").Value)
    Dim vMediaRec As Double: vMediaRec = IIf(IsError(ws.Range("E20").Value), 0, ws.Range("E20").Value)
    Dim mediaTotal As String: mediaTotal = Format(vMedia, "0.00")
    Dim mediaRecortada As String: mediaRecortada = Format(vMediaRec, "0.00")
    
    Dim vDesvTipica As Double: vDesvTipica = IIf(IsError(ws.Range("E6").Value), 0, ws.Range("E6").Value)
    Dim desvTipica As String: desvTipica = Format(vDesvTipica, "0.00")
    Dim vCoefVar As Double: vCoefVar = IIf(IsError(ws.Range("E7").Value), 0, ws.Range("E7").Value)
    Dim coefVar As String: coefVar = Format(vCoefVar, "0.00")
    Dim vPorcAprobados As Double: vPorcAprobados = IIf(IsError(ws.Range("E17").Value), 0, ws.Range("E17").Value)
    Dim porcAprobados As String: porcAprobados = Format(vPorcAprobados * 100, "0")
    Dim mediaSuspensos As String: mediaSuspensos = Format(IIf(IsError(ws.Range("E18").Value), 0, ws.Range("E18").Value), "0.00")
    
    Dim txtHomog As String
    If vCoefVar < 0.2 Then
        txtHomog = "homogéneo, facilitando una progresión uniforme"
    Else
        txtHomog = "heterogéneo, complicando una progresión uniforme"
    End If
    
    Dim txtMedianaPos As String
    If vMediana > vMedia Then
        txtMedianaPos = "por encima del promedio, sugiriendo una concentración de notas altas"
    ElseIf vMediana < vMedia Then
        txtMedianaPos = "por debajo del promedio, sugiriendo un lastre por notas bajas"
    Else
        txtMedianaPos = "alineada con el promedio, indicando una distribución equilibrada"
    End If

    Dim vDificultad As Double: vDificultad = IIf(IsError(ws.Range("E22").Value), 0, ws.Range("E22").Value)
    Dim txtDificultad As String
    Select Case vDificultad
        Case Is >= 0.9: txtDificultad = "muy fácil"
        Case Is >= 0.75: txtDificultad = "fácil"
        Case Is >= 0.45: txtDificultad = "normal"
        Case Is >= 0.25: txtDificultad = "difícil"
        Case Else: txtDificultad = "muy difícil"
    End Select
    
    Dim vDiscriminacion As Double: vDiscriminacion = IIf(IsError(ws.Range("E21").Value), 0, ws.Range("E21").Value)
    Dim txtDiscrim As String
    Select Case vDiscriminacion
        Case Is >= 0.4: txtDiscrim = "mucho"
        Case Is >= 0.2: txtDiscrim = "adecuadamente"
        Case Else: txtDiscrim = "poco"
    End Select
    
    Dim vAsimetria As Double: vAsimetria = IIf(IsError(ws.Range("E10").Value), 0, ws.Range("E10").Value)
    Dim vCurtosis As Double: vCurtosis = IIf(IsError(ws.Range("E11").Value), 0, ws.Range("E11").Value)
    Dim txtAsimetriaExplicada As String
    Dim txtCurtosisExplicada As String
    
    Select Case vAsimetria
        Case Is <= -1: txtAsimetriaExplicada = "La asimetría es de |" & Format(vAsimetria, "0.00") & "|, lo que quiere decir que hay una |fuerte asimetría negativa|: cola larga hacia notas bajas y presencia de valores muy bajos."
        Case -1 To -0.5: txtAsimetriaExplicada = "La asimetría es de |" & Format(vAsimetria, "0.00") & "|, lo que quiere decir que existe una |asimetría negativa moderada|: más dispersión en el tramo inferior."
        Case -0.5 To -0.3: txtAsimetriaExplicada = "La asimetría es de |" & Format(vAsimetria, "0.00") & "|, lo que quiere decir que hay una |leve asimetría negativa|: cola ligera hacia notas bajas."
        Case -0.3 To 0.3: txtAsimetriaExplicada = "La asimetría es de |" & Format(vAsimetria, "0.00") & "|, lo que quiere decir que la distribución es |prácticamente simétrica|: sin sesgo apreciable."
        Case 0.3 To 0.5: txtAsimetriaExplicada = "La asimetría es de |" & Format(vAsimetria, "0.00") & "|, lo que quiere decir que hay una |leve asimetría positiva|: cola ligera hacia notas altas."
        Case 0.5 To 1: txtAsimetriaExplicada = "La asimetría es de |" & Format(vAsimetria, "0.00") & "|, lo que quiere decir que existe una |asimetría positiva moderada|: mayor dispersión en el tramo superior."
        Case Is >= 1: txtAsimetriaExplicada = "La asimetría es de |" & Format(vAsimetria, "0.00") & "|, lo que quiere decir que hay una |fuerte asimetría positiva|: cola larga hacia notas altas y presencia de valores muy altos."
    End Select

    Select Case vCurtosis
        Case Is <= -1: txtCurtosisExplicada = "La curtosis es de |" & Format(vCurtosis, "0.00") & "|, lo que quiere decir que la distribución es |muy platicúrtica|: muy aplanada y con pocos extremos."
        Case -1 To -0.5: txtCurtosisExplicada = "La curtosis es de |" & Format(vCurtosis, "0.00") & "|, lo que quiere decir que la distribución es |platicúrtica|: ligeramente aplanada y con menos valores extremos."
        Case -0.5 To 0.5: txtCurtosisExplicada = "La curtosis es de |" & Format(vCurtosis, "0.00") & "|, lo que quiere decir que la distribución tiene |curtosis cercana a la normal|: concentración y colas similares a una normal."
        Case 0.5 To 1: txtCurtosisExplicada = "La curtosis es de |" & Format(vCurtosis, "0.00") & "|, lo que quiere decir que la distribución es |ligeramente leptocúrtica|: más concentrada en la media y colas algo más pesadas."
        Case Is >= 1: txtCurtosisExplicada = "La curtosis es de |" & Format(vCurtosis, "0.00") & "|, lo que quiere decir que la distribución es |fuertemente leptocúrtica|: muy picuda y con colas pesadas, mayor probabilidad de extremos."
    End Select

    Dim outInf As Long: outInf = IIf(IsError(ws.Range("E16").Value), 0, ws.Range("E16").Value)
    Dim outSup As Long: outSup = IIf(IsError(ws.Range("E17").Value), 0, ws.Range("E17").Value)
    Dim comparacionMedia As String, influenciaAtipicos As String
    If vMediaRec > vMedia Then comparacionMedia = "mayor" Else comparacionMedia = "menor"
    If vMediaRec - vMedia <> 0 Then influenciaAtipicos = "existen" Else influenciaAtipicos = "no existen"
    
    Dim Q1 As Double: Q1 = IIf(IsError(ws.Range("E12").Value), 0, ws.Range("E12").Value)
    Dim Q3 As Double: Q3 = IIf(IsError(ws.Range("E13").Value), 0, ws.Range("E13").Value)
    Dim ric As Double: ric = Q3 - Q1
    Dim dispersion As String
    Select Case ric
        Case Is < 1.5: dispersion = "bajo"
        Case Is < 3: dispersion = "moderado"
        Case Else: dispersion = "alto"
    End Select
    
    Dim p90 As String: p90 = Format(IIf(IsError(ws.Range("E14").Value), 0, ws.Range("E14").Value), "0.00")
    Dim alumnosTop As String: alumnosTop = IIf(IsError(ws.Range("E15").Value), "0", ws.Range("E15").Value)
    
    ultimaFila = ws.Cells(ws.Rows.count, "B").End(xlUp).Row
    If ultimaFila < 6 Then ultimaFila = 6
    Set rngCalificaciones = ws.Range("B6:B" & ultimaFila)
    Set rngNombres = ws.Range("A6:A" & ultimaFila)
    
    Dim p10Val As Double: On Error Resume Next: p10Val = Application.WorksheetFunction.Percentile_Inc(rngCalificaciones, 0.1): On Error GoTo 0
    Dim p10 As String: p10 = Format(p10Val, "0.00")
    
    Dim notaMax As Double: On Error Resume Next: notaMax = Application.WorksheetFunction.Max(rngCalificaciones): On Error GoTo 0
    Dim notaMin As Double: On Error Resume Next: notaMin = Application.WorksheetFunction.Min(rngCalificaciones): On Error GoTo 0
    Dim vRango As Double: vRango = notaMax - notaMin
    
    On Error Resume Next
    Dim nombreMax As String: nombreMax = Application.WorksheetFunction.Index(rngNombres, Application.WorksheetFunction.Match(notaMax, rngCalificaciones, 0))
    Dim nombreMin As String: nombreMin = Application.WorksheetFunction.Index(rngNombres, Application.WorksheetFunction.Match(notaMin, rngCalificaciones, 0))
    On Error GoTo 0
    
    Dim alumnosRiesgo As Long: alumnosRiesgo = 0
    For Each celda In rngCalificaciones
        If IsNumeric(celda.Value) And celda.Value <> "" Then
            If celda.Value < 3 Then alumnosRiesgo = alumnosRiesgo + 1
        End If
    Next celda
    
    Dim txtRiesgo As String
    If alumnosRiesgo > 0 Then
        txtRiesgo = "Existen |" & alumnosRiesgo & " alumnos con calificación inferior a 3.0|, considerados en |riesgo académico|. Se recomienda analizar su rendimiento individualmente mediante informe específico y valorar un posible |plan de acción tutorial|."
    Else
        txtRiesgo = "No existe |ningún alumno con calificación inferior a 3.0|, por lo que se recomienda |mantener la estrategia docente actual|."
    End If
    
    Dim totalAlumnos As Long: totalAlumnos = Application.WorksheetFunction.count(rngCalificaciones)
    Dim noPresentados As Long: noPresentados = Application.WorksheetFunction.CountIf(rngCalificaciones, "NP")
    Dim aprobadosCount As Long: aprobadosCount = Application.WorksheetFunction.CountIf(rngCalificaciones, "Aprobado en otro curso")
    Dim reconocimientos As Long: reconocimientos = Application.WorksheetFunction.CountIf(rngCalificaciones, "Reconocimiento Créditos")
    
    Dim vAprobadosE16 As Long: vAprobadosE16 = IIf(IsError(ws.Range("E16").Value), 0, ws.Range("E16").Value)
    Dim numSuspensos As Long: numSuspensos = totalAlumnos - vAprobadosE16

    Dim tipoExamen As String

    If vMedia <= 4 And vPorcAprobados <= 0.35 Then
        tipoExamen = "Examen Muy Duro"
    ElseIf vMedia >= 7.5 And vPorcAprobados >= 0.75 Then
        tipoExamen = "Excelencia Generalizada"
    ElseIf vCoefVar >= 0.35 And (vPorcAprobados >= 0.45 And vPorcAprobados <= 0.55) And Abs(vAsimetria) <= 0.2 Then
        tipoExamen = "Examen Polarizado"
    ElseIf vMedia >= 7 And vCoefVar <= 0.2 Then
        tipoExamen = "Alto Rendimiento Estable"
    ElseIf vMedia >= 7 And vCoefVar > 0.2 Then
        tipoExamen = "Alto Rendimiento Irregular"
    ElseIf (vMedia >= 5 And vMedia <= 6) And vDesvTipica <= 1 Then
        tipoExamen = "Aprobado Generalizado"
    ElseIf (vMedia >= 5 And vMedia <= 7) And Abs(vAsimetria) <= 0.6 Then
        tipoExamen = "Campana Equilibrada"
    ElseIf vCoefVar >= 0.2 And vRango >= 5 Then
        tipoExamen = "Examen Discriminativo"
    ElseIf vCoefVar <= 0.18 And vRango <= 4 Then
        tipoExamen = "Examen Poco Discriminativo"
    ElseIf vMedia <= 5 And vPorcAprobados <= 0.5 Then
        tipoExamen = "Examen Duro"
    Else
        tipoExamen = "Examen de Perfil Estándar"
    End If

    txtExamen = "INFORME PERSONALIZADO EXAMEN" & vbCrLf & vbCrLf & _
                "El examen |" & nombreExamen & "| ha sido realizado por un total de |" & totalAlumnos & _
                " alumnos| y ha habido |" & noPresentados & " no presentados (NP)|, |" & aprobadosCount & _
                " aprobados en otro curso| y |" & reconocimientos & " reconocimientos de créditos|." & vbCrLf & vbCrLf & _
                "Esta prueba tiene una ponderación del |" & ponderacion & "| en la nota final y se ha obtenido una calificación media de |" & _
                mediaTotal & "| (DT = |" & desvTipica & "|; CV = |" & coefVar & "|), con un |" & porcAprobados & _
                "% de aprobados| y |" & numSuspensos & " alumnos suspensos|, cuya media es |" & mediaSuspensos & "|. " & _
                "El coeficiente de variación sugiere un grupo |" & txtHomog & "|." & vbCrLf & vbCrLf & _
                "La mediana se sitúa en |" & Format(vMediana, "0.00") & "|, encontrándose |" & txtMedianaPos & "|. " & vbCrLf & vbCrLf & _
                "La nota mínima obtenida es |" & notaMin & "|, lograda por |" & nombreMin & "|, y la máxima es |" & notaMax & _
                "|, obtenida por |" & nombreMax & "|. El 50% central del alumnado se sitúa entre |" & Q1 & " (Q1)| y |" & Q3 & _
                " (Q3)|, con un rango intercuartílico de |" & Format(ric, "0.00") & "|, lo que indica un nivel de distribución |" & dispersion & "|." & vbCrLf & vbCrLf & _
                "El percentil 10 se sitúa en |" & p10 & "| y el percentil 90 en |" & p90 & "|." & vbCrLf & vbCrLf & _
                "La media recortada es |" & mediaRecortada & "|, siendo |" & comparacionMedia & "| que la media, lo que indica que |" & _
                influenciaAtipicos & "| valores atípicos relevantes." & vbCrLf & vbCrLf & _
                txtAsimetriaExplicada & vbCrLf & vbCrLf & _
                txtCurtosisExplicada & vbCrLf & vbCrLf & _
                "El examen presenta un índice de dificultad de |" & Format(vDificultad, "0.00") & "| (|" & txtDificultad & "|) y un índice de discriminación de |" & _
                Format(vDiscriminacion, "0.00") & "|, lo que sugiere que la prueba ha discriminado |" & txtDiscrim & "| entre alumnado de alto y bajo rendimiento." & vbCrLf & vbCrLf & _
                txtRiesgo & vbCrLf & vbCrLf & _
                "En base a los indicadores analizados, la prueba se clasifica como un |" & tipoExamen & "|."

    Dim rngPosicion As Range: Set rngPosicion = ws.Range("AI4:AR40")
    On Error Resume Next: ws.Shapes("ResumenExamen").Delete: On Error GoTo 0
    
    Set shp = ws.Shapes.AddTextbox(msoTextOrientationHorizontal, _
              rngPosicion.Left, rngPosicion.Top, _
              rngPosicion.Width - 25, rngPosicion.Height)
              
    With shp
        .Name = "ResumenExamen"
        .Line.Visible = msoTrue: .Line.ForeColor.RGB = RGB(0, 0, 0): .Line.Weight = 3
        .Fill.ForeColor.RGB = RGB(255, 255, 255)
        With .TextFrame2
            .TextRange.Text = txtExamen
            .TextRange.Font.Name = "Calibri": .TextRange.Font.Size = 14: .WordWrap = msoTrue
            .MarginLeft = 8: .MarginRight = 8: .MarginTop = 8: .MarginBottom = 8
            With .TextRange.Lines(1): .Font.bold = True: .Font.Size = 14: .Font.UnderlineStyle = msoUnderlineSingleLine: End With
            
            Dim iStart As Long, iEnd As Long
            Do
                iStart = InStr(.TextRange.Text, "|")
                If iStart = 0 Then Exit Do
                .TextRange.Characters(iStart, 1).Delete
                iEnd = InStr(iStart, .TextRange.Text, "|")
                If iEnd > 0 Then
                    .TextRange.Characters(iStart, iEnd - iStart).Font.bold = True
                    .TextRange.Characters(iEnd, 1).Delete
                End If
            Loop
        End With
    End With
    
    ActiveWindow.Zoom = 50

     With ActiveWindow
        .ScrollRow = 1
        .ScrollColumn = 1
    End With
    
     ActiveSheet.Range("AG3").Select
    Application.ScreenUpdating = True
End Sub

